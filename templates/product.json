            "custom_liquid_tbjyhK": {
              "type": "custom-liquid",
              "name": "t:names.custom_liquid",
              "settings": {
                "custom_liquid": "{% if product.metafields.allergens.icons != blank %}\n  <div class=\"pdp-allergens\">\n    {% for file in product.metafields.allergens.icons.value %}\n      {%- assign allergen_name = file | split: '/' | last | split: '.' | first | replace: '_', ' ' | replace: '-', ' ' -%}\n      <div class=\"pdp-allergen__item\">\n        <img\n          src=\"https://cdn.shopify.com/s/files/1/0965/9793/4353/{{ file }}\"\n          alt=\"{{ allergen_name }}\"\n          loading=\"lazy\"\n        >\n        <span class=\"pdp-allergen__name\">{{ allergen_name }}</span>\n      </div>\n    {% endfor %}\n  </div>\n\n  <style>\n    .pdp-allergens {\n      display: flex;\n      flex-wrap: wrap;\n      gap: 12px 16px;\n      align-items: flex-start;\n      margin-top: 12px;\n    }\n    .pdp-allergen__item {\n      display: flex;\n      align-items: center;\n      gap: 6px;\n    }\n    .pdp-allergen__item img {\n      display: block;\n      width: 28px;\n      height: 28px;\n      object-fit: contain;\n      flex-shrink: 0;\n    }\n    .pdp-allergen__name {\n      font-size: 12px;\n      line-height: 1.3;\n      white-space: nowrap;\n      color: currentColor;\n    }\n  </style>\n{% endif %}"
              },
              "blocks": {}
            },
            "custom_liquid_PndqUY": {
              "type": "custom-liquid",
              "name": "Nutri Score",
              "settings": {
                "custom_liquid": "{% assign nutriscore = product.metafields.product.nutriscore.value | upcase | strip %}\n\n{% if nutriscore != blank %}\n  <div class=\"nutriscore-wrap\">\n\n    <div class=\"nutriscore__header\">\n      <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\">\n        <path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/>\n      </svg>\n      <span class=\"nutriscore__title\">Nutri-score</span>\n      <div class=\"nutriscore__info-wrap\">\n        <button class=\"nutriscore__info-btn\" type=\"button\" aria-label=\"What is Nutri-score?\">i</button>\n        <div class=\"nutriscore__tooltip-box\">\n          Nutritional Rating System demonstrating the overall nutritional value of food products\n        </div>\n      </div>\n    </div>\n\n    <div class=\"nutriscore__bar-wrap\">\n\n      {%- comment %}\n        Bar is divided into 5 equal zones of 20% each.\n        Center of each zone: A=10%, B=30%, C=50%, D=70%, E=90%\n      {%- endcomment %}\n\n      {%- if nutriscore == 'A' -%}{%- assign pointer_pct = 10 -%}\n      {%- elsif nutriscore == 'B' -%}{%- assign pointer_pct = 30 -%}\n      {%- elsif nutriscore == 'C' -%}{%- assign pointer_pct = 50 -%}\n      {%- elsif nutriscore == 'D' -%}{%- assign pointer_pct = 70 -%}\n      {%- elsif nutriscore == 'E' -%}{%- assign pointer_pct = 90 -%}\n      {%- else -%}{%- assign pointer_pct = 50 -%}\n      {%- endif -%}\n\n      <div class=\"nutriscore__pointer\" style=\"left: {{ pointer_pct }}%;\">\n        <svg width=\"12\" height=\"9\" viewBox=\"0 0 12 9\" aria-hidden=\"true\">\n          <polygon points=\"6,9 0,0 12,0\" fill=\"currentColor\"/>\n        </svg>\n      </div>\n\n      <div class=\"nutriscore__bar\">\n        <span class=\"nutriscore__zone nutriscore__zone--a{% if nutriscore == 'A' %} is-active{% endif %}\">A</span>\n        <span class=\"nutriscore__zone nutriscore__zone--b{% if nutriscore == 'B' %} is-active{% endif %}\">B</span>\n        <span class=\"nutriscore__zone nutriscore__zone--c{% if nutriscore == 'C' %} is-active{% endif %}\">C</span>\n        <span class=\"nutriscore__zone nutriscore__zone--d{% if nutriscore == 'D' %} is-active{% endif %}\">D</span>\n        <span class=\"nutriscore__zone nutriscore__zone--e{% if nutriscore == 'E' %} is-active{% endif %}\">E</span>\n      </div>\n\n    </div>\n  </div>\n\n  <style>\n    .nutriscore-wrap {\n      border: 1px solid #e8e8e8;\n      border-radius: 12px;\n      padding: 16px 20px 20px;\n      background: #fafafa;\n      margin-top: 16px;\n    }\n\n    .nutriscore__header {\n      display: flex;\n      align-items: center;\n      gap: 8px;\n      margin-bottom: 20px;\n      color: #1a2e0a;\n    }\n    .nutriscore__title {\n      font-size: 15px;\n      font-weight: 500;\n      color: #1a1a1a;\n    }\n\n    .nutriscore__info-wrap {\n      position: relative;\n      display: inline-flex;\n    }\n    .nutriscore__info-btn {\n      width: 18px;\n      height: 18px;\n      border-radius: 50%;\n      border: 1.5px solid #999;\n      background: transparent;\n      color: #999;\n      font-size: 11px;\n      font-style: italic;\n      font-weight: 600;\n      cursor: pointer;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      padding: 0;\n      line-height: 1;\n    }\n    .nutriscore__tooltip-box {\n      position: absolute;\n      bottom: calc(100% + 8px);\n      left: 50%;\n      transform: translateX(-50%);\n      background: #1a1a1a;\n      color: #fff;\n      font-size: 12px;\n      line-height: 1.5;\n      padding: 8px 12px;\n      border-radius: 6px;\n      width: 240px;\n      white-space: normal;\n      pointer-events: none;\n      opacity: 0;\n      transition: opacity 0.15s ease;\n      z-index: 20;\n      text-align: center;\n    }\n    .nutriscore__tooltip-box::after {\n      content: '';\n      position: absolute;\n      top: 100%;\n      left: 50%;\n      transform: translateX(-50%);\n      border: 5px solid transparent;\n      border-top-color: #1a1a1a;\n    }\n    .nutriscore__info-wrap:hover .nutriscore__tooltip-box {\n      opacity: 1;\n    }\n\n    .nutriscore__bar-wrap {\n      position: relative;\n      padding-top: 18px;\n    }\n\n    .nutriscore__pointer {\n      position: absolute;\n      top: 0;\n      transform: translateX(-50%);\n      color: #1a1a1a;\n      display: flex;\n      justify-content: center;\n      line-height: 1;\n    }\n\n    .nutriscore__bar {\n      display: flex;\n      border-radius: 6px;\n      overflow: hidden;\n      height: 36px;\n    }\n\n    .nutriscore__zone {\n      flex: 1;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      font-size: 14px;\n      font-weight: 700;\n      color: rgba(255,255,255,0.55);\n      cursor: default;\n      transition: color 0.2s;\n      letter-spacing: 0.02em;\n    }\n    .nutriscore__zone.is-active {\n      color: #ffffff;\n    }\n\n    .nutriscore__zone--a { background: #2d8a2d; }\n    .nutriscore__zone--b { background: #85bb2f; }\n    .nutriscore__zone--c { background: #f5c400; }\n    .nutriscore__zone--d { background: #f07a00; }\n    .nutriscore__zone--e { background: #d93025; }\n  </style>\n{% endif %}"
              },
