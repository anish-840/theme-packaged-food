                    "custom_liquid": "{% assign card_product = closest.product %}\n{% assign allergen_icons = card_product.metafields.allergens.icons %}\n\n{% if allergen_icons != blank %}\n  <div class=\"card-allergens\">\n    {% for file in allergen_icons.value %}\n      {%- assign allergen_name = file | split: '/' | last | split: '.' | first | replace: '_', ' ' | replace: '-', ' ' -%}\n      <div class=\"card-allergen__item\">\n        <img\n          src=\"https://cdn.shopify.com/s/files/1/0965/9793/4353/{{ file }}\"\n          alt=\"{{ allergen_name }}\"\n          loading=\"lazy\"\n        >\n        <span class=\"card-allergen__tooltip\">{{ allergen_name }}</span>\n      </div>\n    {% endfor %}\n  </div>\n\n  <style>\n    .card-allergens {\n      display: flex;\n      flex-wrap: wrap;\n      gap: 6px;\n      align-items: center;\n      margin-top: 8px;\n    }\n    .card-allergen__item {\n      position: relative;\n      display: inline-flex;\n      align-items: center;\n      justify-content: center;\n    }\n    .card-allergen__item img {\n      display: block;\n      width: 28px;\n      height: 28px;\n      object-fit: contain;\n      flex-shrink: 0;\n      cursor: pointer;\n    }\n    .card-allergen__tooltip {\n      position: absolute;\n      bottom: calc(100% + 6px);\n      left: 50%;\n      transform: translateX(-50%);\n      background: #1a2e0a;\n      color: #ffffff;\n      font-size: 11px;\n      font-weight: 500;\n      white-space: nowrap;\n      padding: 4px 8px;\n      border-radius: 4px;\n      pointer-events: none;\n      opacity: 0;\n      transition: opacity 0.15s ease;\n      z-index: 10;\n    }\n    .card-allergen__tooltip::after {\n      content: '';\n      position: absolute;\n      top: 100%;\n      left: 50%;\n      transform: translateX(-50%);\n      border: 4px solid transparent;\n      border-top-color: #1a2e0a;\n    }\n    .card-allergen__item:hover .card-allergen__tooltip {\n      opacity: 1;\n    }\n  </style>\n{% endif %}"
