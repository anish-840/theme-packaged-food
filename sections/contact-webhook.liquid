<style>
  .minimal-contact-section {
    max-width: 700px;
    margin: 60px auto;
    padding: 0 20px;
    font-family: inherit;
    color: #1a1a1a;
  }

  .minimal-contact-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .minimal-contact-header h2 {
    font-size: {{ section.settings.heading_size }}px;
    font-weight: 500;
    margin-bottom: 12px;
  }

  .minimal-contact-header p {
    color: #555;
    font-size: 16px;
    margin: 0;
  }

  .minimal-form-group {
    margin-bottom: 24px;
  }

  .minimal-form-row {
    display: flex;
    gap: 24px;
    margin-bottom: 24px;
  }

  .minimal-form-col {
    flex: 1;
  }

  .minimal-contact-form label {
    display: block;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 8px;
    color: #555;
  }

  .minimal-contact-form input,
  .minimal-contact-form select,
  .minimal-contact-form textarea {
    width: 100%;
    padding: 14px 16px;
    border: 1px solid #e5e5e5;
    border-radius: 4px;
    font-size: 15px;
    font-family: inherit;
    background: #fafafa;
    transition: all 0.3s ease;
    box-sizing: border-box;
  }

  .minimal-contact-form input:focus,
  .minimal-contact-form select:focus,
  .minimal-contact-form textarea:focus {
    outline: none;
    border-color: #1a1a1a;
    background: #fff;
  }

  .minimal-contact-form textarea {
    resize: vertical;
    min-height: 120px;
  }

  .minimal-submit-btn {
    background-color: {{ section.settings.btn_color }};
    color: #fff;
    border: none;
    padding: 16px 32px;
    font-size: 16px;
    font-weight: 500;
    border-radius: 4px;
    cursor: pointer;
    width: 100%;
    transition: opacity 0.3s ease;
  }

  .minimal-submit-btn:hover {
    opacity: 0.85;
  }

  .minimal-submit-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .form-message {
    padding: 16px;
    border-radius: 4px;
    margin-top: 24px;
    text-align: center;
    font-size: 15px;
    display: none;
  }

  .form-success {
    background-color: #f0fdf4;
    color: #166534;
    border: 1px solid #bbf7d0;
  }

  .form-error {
    background-color: #fef2f2;
    color: #991b1b;
    border: 1px solid #fecaca;
  }

  @media (max-width: 600px) {
    .minimal-form-row {
      flex-direction: column;
      gap: 0;
      margin-bottom: 0;
    }
    .minimal-form-row .minimal-form-col {
      margin-bottom: 24px;
    }
  }
</style>

<div class="minimal-contact-section">
  <div class="minimal-contact-header">
    {% if section.settings.heading != blank %}
      <h2>{{ section.settings.heading }}</h2>
    {% endif %}
    {% if section.settings.subheading != blank %}
      <p>{{ section.settings.subheading }}</p>
    {% endif %}
  </div>

  <form id="WebhookContactForm-{{ section.id }}" class="minimal-contact-form">
    <div class="minimal-form-row">
      <div class="minimal-form-col">
        <label for="name-{{ section.id }}">Name</label>
        <input type="text" id="name-{{ section.id }}" name="name" required placeholder="John Doe">
      </div>
      <div class="minimal-form-col">
        <label for="email-{{ section.id }}">Email</label>
        <input type="email" id="email-{{ section.id }}" name="email" required placeholder="john@example.com">
      </div>
    </div>

    <div class="minimal-form-row">
      <div class="minimal-form-col">
        <label for="phone-{{ section.id }}">Phone</label>
        <input type="tel" id="phone-{{ section.id }}" name="phone" placeholder="+1 (555) 000-0000">
      </div>
      <div class="minimal-form-col">
        <label for="reason-{{ section.id }}">Reason</label>
        <select id="reason-{{ section.id }}" name="reason" required>
          <option value="" disabled selected>Select a reason...</option>
          <option value="General Inquiry">General Inquiry</option>
          <option value="Support">Support</option>
          <option value="Feedback">Feedback</option>
          <option value="Other">Other</option>
        </select>
      </div>
    </div>

    <div class="minimal-form-group">
      <label for="message-{{ section.id }}">Message</label>
      <textarea id="message-{{ section.id }}" name="message" required placeholder="How can we help you?"></textarea>
    </div>

    <button type="submit" class="minimal-submit-btn" id="SubmitBtn-{{ section.id }}">
      {{ section.settings.btn_text }}
    </button>

    <div class="form-message form-success" id="SuccessMsg-{{ section.id }}">
      {{ section.settings.success_message }}
    </div>
    
    <div class="form-message form-error" id="ErrorMsg-{{ section.id }}">
      Something went wrong. Please check your webhook URL and try again.
    </div>
  </form>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('WebhookContactForm-{{ section.id }}');
    const submitBtn = document.getElementById('SubmitBtn-{{ section.id }}');
    const successMsg = document.getElementById('SuccessMsg-{{ section.id }}');
    const errorMsg = document.getElementById('ErrorMsg-{{ section.id }}');
    const webhookUrl = "{{ section.settings.webhook_url }}";

    form.addEventListener('submit', function(e) {
      e.preventDefault();

      if (!webhookUrl) {
        alert('Webhook URL is missing. Please configure it in the Shopify theme editor.');
        return;
      }

      // Hide previous messages
      successMsg.style.display = 'none';
      errorMsg.style.display = 'none';

      // Update button state
      const originalBtnText = submitBtn.innerText;
      submitBtn.disabled = true;
      submitBtn.innerText = 'Sending...';

      // Gather form data into JSON object
      const formData = new FormData(form);
      const data = Object.fromEntries(formData.entries());
      
      // Add timestamp and page origin context
      data.timestamp = new Date().toISOString();
      data.source = window.location.href;

      // Send POST request
      fetch(webhookUrl, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json'
        },
        body: JSON.stringify(data)
      })
      .then(response => {
        if (response.ok) {
          successMsg.style.display = 'block';
          form.reset();
        } else {
          throw new Error('Network response was not ok');
        }
      })
      .catch(error => {
        console.error('Webhook Error:', error);
        errorMsg.style.display = 'block';
      })
      .finally(() => {
        submitBtn.disabled = false;
        submitBtn.innerText = originalBtnText;
      });
    });
  });
</script>

{% schema %}
{
  "name": "Webhook Contact Form",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Get in Touch"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 20,
      "max": 60,
      "step": 1,
      "unit": "px",
      "label": "Heading Font Size",
      "default": 36
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Fill out the form below and we will get back to you as soon as possible."
    },
    {
      "type": "header",
      "content": "Webhook Configuration"
    },
    {
      "type": "text",
      "id": "webhook_url",
      "label": "POST Webhook URL",
      "info": "The full URL where form data will be sent as JSON (e.g., your n8n, Make, or Zapier catch hook)."
    },
    {
      "type": "header",
      "content": "Button & Messages"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button Text",
      "default": "Send Message"
    },
    {
      "type": "color",
      "id": "btn_color",
      "label": "Button Background Color",
      "default": "#1a1a1a"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success Message",
      "default": "Thank you! Your message has been sent successfully."
    }
  ],
  "presets": [
    {
      "name": "Webhook Contact Form"
    }
  ]
}
{% endschema %}