<style>
  .local-contact-wrap {
    max-width: 800px;
    margin: 60px auto;
    padding: 0 20px;
    font-family: inherit;
    color: #1a1a1a;
  }
  .local-contact-header {
    text-align: center;
    margin-bottom: 40px;
  }
  .local-contact-header h2 {
    font-size: 36px;
    font-weight: 500;
    margin-bottom: 12px;
  }
  .local-contact-header p {
    color: #555;
    font-size: 16px;
    margin: 0;
  }
  .local-contact-form .form-row {
    display: flex;
    gap: 20px;
  }
  .local-contact-form .form-group {
    flex: 1;
    position: relative;
    margin-bottom: 24px;
  }
  .local-contact-form label {
    display: block;
    margin-bottom: 8px;
    font-size: 14px;
    font-weight: 500;
  }
  .local-contact-form input,
  .local-contact-form select,
  .local-contact-form textarea {
    width: 100%;
    padding: 14px 16px;
    border: 1px solid #e2e2e2;
    border-radius: 8px;
    font-size: 15px;
    background: #fff;
    box-sizing: border-box;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .local-contact-form input:focus,
  .local-contact-form select:focus,
  .local-contact-form textarea:focus {
    outline: none;
    border-color: #1a1a1a;
    box-shadow: 0 0 0 1px #1a1a1a;
  }
  .local-contact-form textarea {
    min-height: 120px;
    resize: vertical;
  }
  
  /* Validation Styles */
  .error-text {
    color: #d93025;
    font-size: 13px;
    margin-top: 6px;
    display: none;
  }
  .has-error input,
  .has-error select,
  .has-error textarea {
    border-color: #d93025;
  }
  .has-error .error-text {
    display: block;
  }

  /* Button matching Local Theme pill style */
  .local-btn {
    background: #1a1a1a;
    color: #fff;
    border: none;
    padding: 16px 40px;
    font-size: 16px;
    font-weight: 600;
    border-radius: 50px; 
    cursor: pointer;
    width: 100%;
    transition: background-color 0.3s ease;
  }
  .local-btn:hover {
    background-color: #333;
  }
  .local-btn:disabled {
    background-color: #999;
    cursor: not-allowed;
  }

  .success-banner {
    display: none;
    background: #e6f4ea;
    color: #1e8e3e;
    padding: 16px;
    border-radius: 8px;
    text-align: center;
    margin-bottom: 24px;
    font-weight: 500;
    border: 1px solid #cce8d6;
  }

  @media (max-width: 768px) {
    .local-contact-form .form-row {
      flex-direction: column;
      gap: 0;
    }
  }
</style>

<div class="local-contact-wrap">
  <div class="local-contact-header">
    {% if section.settings.heading != blank %}
      <h2>{{ section.settings.heading }}</h2>
    {% endif %}
    {% if section.settings.subheading != blank %}
      <p>{{ section.settings.subheading }}</p>
    {% endif %}
  </div>

  <div class="success-banner" id="SuccessBanner-{{ section.id }}">
    {{ section.settings.success_msg }}
  </div>

  <form id="LocalContactForm-{{ section.id }}" class="local-contact-form" novalidate>
    <div class="form-row">
      <div class="form-group" id="group-name">
        <label for="ContactFormName">Name</label>
        <input type="text" id="ContactFormName" name="name" placeholder="Your full name">
        <div class="error-text">{{ section.settings.err_name }}</div>
      </div>
      
      <div class="form-group" id="group-email">
        <label for="ContactFormEmail">Email</label>
        <input type="email" id="ContactFormEmail" name="email" placeholder="you@example.com">
        <div class="error-text">{{ section.settings.err_email }}</div>
      </div>
    </div>

    <div class="form-row">
      <div class="form-group" id="group-phone">
        <label for="ContactFormPhone">Phone</label>
        <input type="tel" id="ContactFormPhone" name="phone" placeholder="+1 (555) 000-0000">
        <div class="error-text">{{ section.settings.err_phone }}</div>
      </div>

      <div class="form-group" id="group-reason">
        <label for="ContactFormReason">Reason for Contact</label>
        <select id="ContactFormReason" name="reason">
          <option value="" disabled selected>Please select...</option>
          <option value="Order Status">Order Status</option>
          <option value="Product Question">Product Question</option>
          <option value="Returns/Exchanges">Returns & Exchanges</option>
          <option value="Other">Other</option>
        </select>
        <div class="error-text">{{ section.settings.err_reason }}</div>
      </div>
    </div>

    <div class="form-group" id="group-message">
      <label for="ContactFormMessage">Message</label>
      <textarea id="ContactFormMessage" name="message" placeholder="How can we help you today?"></textarea>
      <div class="error-text">{{ section.settings.err_message }}</div>
    </div>

    <button type="submit" class="local-btn" id="SubmitBtn-{{ section.id }}">
      {{ section.settings.btn_text }}
    </button>
  </form>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('LocalContactForm-{{ section.id }}');
    const btn = document.getElementById('SubmitBtn-{{ section.id }}');
    const successBanner = document.getElementById('SuccessBanner-{{ section.id }}');
    const webhookUrl = "{{ section.settings.webhook_url }}";

    form.addEventListener('submit', function(e) {
      e.preventDefault();
      let isValid = true;

      // Clear previous error states
      form.querySelectorAll('.form-group').forEach(el => el.classList.remove('has-error'));
      successBanner.style.display = 'none';

      // Validation Rules
      const name = form.querySelector('[name="name"]');
      if (!name.value.trim()) {
        document.getElementById('group-name').classList.add('has-error');
        isValid = false;
      }

      const email = form.querySelector('[name="email"]');
      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      if (!email.value.trim() || !emailRegex.test(email.value)) {
        document.getElementById('group-email').classList.add('has-error');
        isValid = false;
      }

      const phone = form.querySelector('[name="phone"]');
      if (!phone.value.trim()) {
        document.getElementById('group-phone').classList.add('has-error');
        isValid = false;
      }

      const reason = form.querySelector('[name="reason"]');
      if (!reason.value) {
        document.getElementById('group-reason').classList.add('has-error');
        isValid = false;
      }

      const message = form.querySelector('[name="message"]');
      if (!message.value.trim()) {
        document.getElementById('group-message').classList.add('has-error');
        isValid = false;
      }

      // Stop submission if invalid
      if (!isValid) return;

      if (!webhookUrl) {
        console.error("Webhook URL is missing.");
        alert("Form setup is incomplete. Missing webhook URL.");
        return;
      }

      // Prepare payload and update UI
      const originalText = btn.innerText;
      btn.innerText = 'Submitting...';
      btn.disabled = true;

      const formData = new FormData(form);
      const data = Object.fromEntries(formData.entries());
      data.timestamp = new Date().toISOString();
      data.source = window.location.href;

      // Dispatch Webhook
      fetch(webhookUrl, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json'
        },
        body: JSON.stringify(data)
      })
      .then(response => {
        if (response.ok) {
          form.reset();
          successBanner.style.display = 'block';
          // Auto-hide success message after 6 seconds
          setTimeout(() => { successBanner.style.display = 'none'; }, 6000);
        } else {
          throw new Error('Webhook failed');
        }
      })
      .catch(error => {
        console.error('Error:', error);
        alert('There was a network error sending your message. Please try again.');
      })
      .finally(() => {
        btn.innerText = originalText;
        btn.disabled = false;
      });
    });
  });
</script>

{% schema %}
{
  "name": "Local Theme Contact Form",
  "settings": [
    {
      "type": "header",
      "content": "Section Setup"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Get in Touch"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "We'd love to hear from you. Fill out the form below."
    },
    {
      "type": "text",
      "id": "webhook_url",
      "label": "Webhook POST URL",
      "info": "Paste your Zapier, Make, or n8n catch hook URL here."
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Submit Button Text",
      "default": "Send Message"
    },
    {
      "type": "header",
      "content": "Success & Validation Messages"
    },
    {
      "type": "text",
      "id": "success_msg",
      "label": "Success Message",
      "default": "Thanks for reaching out! We will get back to you shortly."
    },
    {
      "type": "text",
      "id": "err_name",
      "label": "Name Error",
      "default": "Please enter your full name."
    },
    {
      "type": "text",
      "id": "err_email",
      "label": "Email Error",
      "default": "Please enter a valid email address."
    },
    {
      "type": "text",
      "id": "err_phone",
      "label": "Phone Error",
      "default": "Please enter your phone number."
    },
    {
      "type": "text",
      "id": "err_reason",
      "label": "Reason Error",
      "default": "Please select a reason for contacting us."
    },
    {
      "type": "text",
      "id": "err_message",
      "label": "Message Error",
      "default": "Please provide a message so we can help you."
    }
  ],
  "presets": [
    {
      "name": "Local Theme Contact Form"
    }
  ]
}
{% endschema %}