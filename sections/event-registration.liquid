{% comment %}
  Event Registration Section
  - Section title + description
  - Event selector dropdown (configurable list of events)
  - Form fields: First name, Last name, Email, Phone, Event dropdown
  - Client-side validation
  - Submits via fetch to a configurable webhook URL
  - Styling matches Local theme brand palette
{% endcomment %}

{%- assign sid = 'event-reg-' | append: section.id -%}

<section id="{{ sid }}" class="er-section">
  <div class="er-inner">

    {%- comment %} ── Left: text content ── {%- endcomment %}
    <div class="er-content">
      {%- if section.settings.eyebrow != blank -%}
        <p class="er-eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      {%- if section.settings.title != blank -%}
        <h2 class="er-title">{{ section.settings.title | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <p class="er-description">{{ section.settings.description | escape }}</p>
      {%- endif -%}

      {%- comment %} Event list preview ── {%- endcomment %}
      {%- assign event_blocks = section.blocks | where: 'type', 'event' -%}
      {%- if section.settings.show_event_list and event_blocks.size > 0 -%}
        <ul class="er-event-list" data-er-list>
          {%- for block in event_blocks -%}
            {%- assign list_index = forloop.index0 -%}
            {%- if block.settings.event_name != blank and block.settings.show_in_list -%}
              <li class="er-event-list__item" data-er-item="{{ list_index }}" {{ block.shopify_attributes }}>
                {%- if block.settings.list_icon == 'calendar' -%}
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <rect x="2" y="1" width="12" height="14" rx="2" stroke="currentColor" stroke-width="1.4"/>
                    <path d="M5 1V3M11 1V3M2 6h12" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
                  </svg>
                {%- elsif block.settings.list_icon == 'pin' -%}
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path d="M8 1.5A3.5 3.5 0 0 1 11.5 5c0 2.5-3.5 9-3.5 9S4.5 7.5 4.5 5A3.5 3.5 0 0 1 8 1.5z" stroke="currentColor" stroke-width="1.4"/>
                    <circle cx="8" cy="5" r="1.2" stroke="currentColor" stroke-width="1.2"/>
                  </svg>
                {%- elsif block.settings.list_icon == 'star' -%}
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path d="M8 1l1.545 3.13L13 4.635l-2.5 2.435.59 3.44L8 8.885l-3.09 1.625.59-3.44L3 4.635l3.455-.505z" stroke="currentColor" stroke-width="1.3"/>
                  </svg>
                {%- elsif block.settings.list_icon == 'check' -%}
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.4"/>
                    <path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                {%- endif -%}
                <div>
                  <span
                    class="er-event-list__name"
                    style="
                      font-size: {{ block.settings.list_name_size }}px;
                      color: {{ block.settings.list_name_color }};
                      font-weight: {{ block.settings.list_name_weight }};
                    "
                  >{{ block.settings.event_name | escape }}</span>
                  {%- if block.settings.event_meta != blank -%}
                    <span
                      class="er-event-list__meta"
                      style="color: {{ block.settings.list_meta_color }};"
                    >{{ block.settings.event_meta | escape }}</span>
                  {%- endif -%}
                </div>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}

      {%- comment %} ── Event image gallery ── {%- endcomment %}
      {%- if section.settings.show_event_images and event_blocks.size > 0 -%}
        <div
          class="er-event-gallery"
          style="
            height: {{ section.settings.event_img_height }}px;
            border-radius: {{ section.settings.event_img_radius }}px;
            background: {{ section.settings.event_img_bg }};
          "
          data-er-gallery
        >
          {%- assign img_index = 0 -%}
          {%- for block in event_blocks -%}
            {%- if block.settings.show_in_list -%}
              <div
                class="er-event-gallery__slide{% if img_index == 0 %} is-active{% endif %}"
                data-er-slide="{{ img_index }}"
              >
                {%- if block.settings.event_image != blank -%}
                  {{
                    block.settings.event_image
                    | image_url: width: 900
                    | image_tag:
                      class: 'er-event-gallery__img',
                      loading: 'lazy',
                      widths: '400, 600, 900',
                      sizes: '(max-width: 749px) 100vw, 45vw',
                      alt: block.settings.event_name | escape
                  }}
                {%- else -%}
                  <div class="er-event-gallery__placeholder">
                    <svg width="48" height="48" viewBox="0 0 48 48" fill="none" aria-hidden="true">
                      <rect x="4" y="8" width="40" height="32" rx="4" stroke="currentColor" stroke-width="2" opacity="0.3"/>
                      <circle cx="16" cy="20" r="4" stroke="currentColor" stroke-width="2" opacity="0.3"/>
                      <path d="M4 36l10-10 8 8 6-6 16 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" opacity="0.3"/>
                    </svg>
                    <span>{{ block.settings.event_name | escape }}</span>
                  </div>
                {%- endif -%}
              </div>
              {%- assign img_index = img_index | plus: 1 -%}
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

    </div>

    {%- comment %} ── Right: form ── {%- endcomment %}
    <div class="er-form-wrap">
      <div class="er-form-card">

        {%- if section.settings.form_title != blank -%}
          <h3 class="er-form-title">{{ section.settings.form_title | escape }}</h3>
        {%- endif -%}
        {%- if section.settings.form_subtitle != blank -%}
          <p class="er-form-subtitle">{{ section.settings.form_subtitle | escape }}</p>
        {%- endif -%}

        <form class="er-form" id="{{ sid }}-form" novalidate>

          {%- comment %} Name row {%- endcomment %}
          <div class="er-row">
            <div class="er-field">
              <label class="er-label" for="{{ sid }}-fname">
                {{ section.settings.label_firstname | default: 'First name' }}
                <span class="er-required" aria-hidden="true">*</span>
              </label>
              <input
                type="text"
                id="{{ sid }}-fname"
                name="first_name"
                class="er-input"
                placeholder="{{ section.settings.placeholder_firstname | default: 'Jane' }}"
                required
                autocomplete="given-name"
              >
              <span class="er-error" data-error="first_name"></span>
            </div>
            <div class="er-field">
              <label class="er-label" for="{{ sid }}-lname">
                {{ section.settings.label_lastname | default: 'Last name' }}
                <span class="er-required" aria-hidden="true">*</span>
              </label>
              <input
                type="text"
                id="{{ sid }}-lname"
                name="last_name"
                class="er-input"
                placeholder="{{ section.settings.placeholder_lastname | default: 'Smith' }}"
                required
                autocomplete="family-name"
              >
              <span class="er-error" data-error="last_name"></span>
            </div>
          </div>

          {%- comment %} Email {%- endcomment %}
          <div class="er-field">
            <label class="er-label" for="{{ sid }}-email">
              {{ section.settings.label_email | default: 'Email address' }}
              <span class="er-required" aria-hidden="true">*</span>
            </label>
            <input
              type="email"
              id="{{ sid }}-email"
              name="email"
              class="er-input"
              placeholder="{{ section.settings.placeholder_email | default: 'jane@example.com' }}"
              required
              autocomplete="email"
            >
            <span class="er-error" data-error="email"></span>
          </div>

          {%- comment %} Phone {%- endcomment %}
          {%- if section.settings.show_phone -%}
            <div class="er-field">
              <label class="er-label" for="{{ sid }}-phone">
                {{ section.settings.label_phone | default: 'Phone number' }}
                {%- if section.settings.phone_required -%}
                  <span class="er-required" aria-hidden="true">*</span>
                {%- else -%}
                  <span class="er-optional">({{ section.settings.optional_label | default: 'optional' }})</span>
                {%- endif -%}
              </label>
              <input
                type="tel"
                id="{{ sid }}-phone"
                name="phone"
                class="er-input"
                placeholder="{{ section.settings.placeholder_phone | default: '+1 555 000 0000' }}"
                {% if section.settings.phone_required %}required{% endif %}
                autocomplete="tel"
              >
              <span class="er-error" data-error="phone"></span>
            </div>
          {%- endif -%}

          {%- comment %} Event selector {%- endcomment %}
          <div class="er-field">
            <label class="er-label" for="{{ sid }}-event">
              {{ section.settings.label_event | default: 'Select event' }}
              <span class="er-required" aria-hidden="true">*</span>
            </label>
            <div class="er-select-wrap">
              <select
                id="{{ sid }}-event"
                name="event"
                class="er-select"
                required
              >
                <option value="">{{ section.settings.event_placeholder | default: '— Choose an event —' }}</option>
                {%- for block in section.blocks -%}
                  {%- if block.type == 'event' and block.settings.event_name != blank -%}
                    {%- assign opt_value = block.settings.event_value | default: block.settings.event_name -%}
                    <option value="{{ opt_value | escape }}">{{ block.settings.event_name | escape }}</option>
                  {%- endif -%}
                {%- endfor -%}
              </select>
              <svg class="er-select-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <span class="er-error" data-error="event"></span>
          </div>

          {%- comment %} Message {%- endcomment %}
          {%- if section.settings.show_message -%}
            <div class="er-field">
              <label class="er-label" for="{{ sid }}-message">
                {{ section.settings.label_message | default: 'Message' }}
                <span class="er-optional">({{ section.settings.optional_label | default: 'optional' }})</span>
              </label>
              <textarea
                id="{{ sid }}-message"
                name="message"
                class="er-input er-textarea"
                placeholder="{{ section.settings.placeholder_message | default: 'Any dietary requirements or questions?' }}"
                rows="3"
              ></textarea>
            </div>
          {%- endif -%}

          {%- comment %} Submit {%- endcomment %}
          <button type="submit" class="er-btn" id="{{ sid }}-submit">
            <span class="er-btn__label">{{ section.settings.btn_label | default: 'Register now' }}</span>
            <span class="er-btn__spinner" aria-hidden="true"></span>
          </button>

          {%- comment %} Success / error messages {%- endcomment %}
          <div class="er-status er-status--success" id="{{ sid }}-success" role="alert" aria-live="polite">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <circle cx="10" cy="10" r="9" stroke="currentColor" stroke-width="1.5"/>
              <path d="M6 10l3 3 5-5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            {{ section.settings.success_message | default: "You're registered! We'll be in touch soon." | escape }}
          </div>
          <div class="er-status er-status--error" id="{{ sid }}-error" role="alert" aria-live="polite">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <circle cx="10" cy="10" r="9" stroke="currentColor" stroke-width="1.5"/>
              <path d="M10 6v5M10 14h.01" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
            </svg>
            {{ section.settings.error_message | default: 'Something went wrong. Please try again.' | escape }}
          </div>

        </form>
      </div>
    </div>

  </div>
</section>

<style>
  #{{ sid }} {
    padding: {{ section.settings.section_padding_top }}px {{ section.settings.section_padding_x }}px {{ section.settings.section_padding_bottom }}px;
    background: {{ section.settings.section_bg }};
  }

  #{{ sid }} .er-inner {
    display: grid;
    grid-template-columns: {{ section.settings.content_cols }}fr {{ section.settings.form_cols }}fr;
    gap: {{ section.settings.col_gap }}px;
    align-items: start;
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
  }

  /* ── Left content ── */
  #{{ sid }} .er-eyebrow {
    font-size: {{ section.settings.eyebrow_size }}px;
    font-weight: 500;
    color: {{ section.settings.accent_color }};
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0 0 10px;
  }
  #{{ sid }} .er-title {
    font-size: {{ section.settings.title_size }}px;
    font-weight: {{ section.settings.title_weight }};
    color: {{ section.settings.title_color }};
    line-height: 1.2;
    margin: 0 0 16px;
  }
  #{{ sid }} .er-description {
    font-size: {{ section.settings.desc_size }}px;
    color: {{ section.settings.desc_color }};
    line-height: 1.65;
    margin: 0 0 24px;
  }

  /* Event list */
  #{{ sid }} .er-event-list {
    list-style: none;
    margin: 0; padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  #{{ sid }} .er-event-list__item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    color: {{ section.settings.desc_color }};
  }
  #{{ sid }} .er-event-list__item svg {
    color: {{ section.settings.accent_color }};
    flex-shrink: 0;
  }
  #{{ sid }} .er-event-list__name {
    display: block;
    font-size: 14px;
    color: {{ section.settings.desc_color }};
    font-weight: 500;
  }
  #{{ sid }} .er-event-list__meta {
    display: block;
    font-size: 12px;
    color: {{ section.settings.desc_color }};
    opacity: 0.7;
  }

  /* ── Active list item highlight ── */
  #{{ sid }} .er-event-list__item {
    cursor: pointer;
    border-radius: 8px;
    padding: 6px 8px;
    margin: 0 -8px;
    transition: background 0.15s;
  }
  #{{ sid }} .er-event-list__item:hover,
  #{{ sid }} .er-event-list__item.is-active {
    background: rgba(45, 80, 22, 0.06);
  }
  #{{ sid }} .er-event-list__item.is-active .er-event-list__name {
    color: {{ section.settings.accent_color }} !important;
  }
  #{{ sid }} .er-event-list__item svg {
    transition: color 0.15s;
  }
  #{{ sid }} .er-event-list__item.is-active svg,
  #{{ sid }} .er-event-list__item:hover svg {
    color: {{ section.settings.accent_color }};
  }

  /* ── Event image gallery ── */
  #{{ sid }} .er-event-gallery {
    width: 100%;
    overflow: hidden;
    position: relative;
    margin-top: {{ section.settings.event_img_margin_top }}px;
  }
  #{{ sid }} .er-event-gallery__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity {{ section.settings.event_img_transition }}ms ease;
    pointer-events: none;
  }
  #{{ sid }} .er-event-gallery__slide.is-active {
    opacity: 1;
    pointer-events: auto;
    position: relative;
    height: 100%;
  }
  #{{ sid }} .er-event-gallery__img {
    width: 100%;
    height: 100%;
    object-fit: {{ section.settings.event_img_fit }};
    object-position: center;
    display: block;
  }
  #{{ sid }} .er-event-gallery__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    color: {{ section.settings.desc_color }};
    font-size: 13px;
    opacity: 0.5;
  }

  /* ── Form card ── */
  #{{ sid }} .er-form-card {
    background: {{ section.settings.card_bg }};
    border: {{ section.settings.card_border_width }}px solid {{ section.settings.card_border_color }};
    border-radius: {{ section.settings.card_radius }}px;
    padding: {{ section.settings.card_padding }}px;
    box-sizing: border-box;
  }
  #{{ sid }} .er-form-title {
    font-size: {{ section.settings.form_title_size }}px;
    font-weight: {{ section.settings.form_title_weight }};
    color: {{ section.settings.title_color }};
    margin: 0 0 6px;
    line-height: 1.2;
  }
  #{{ sid }} .er-form-subtitle {
    font-size: 13px;
    color: {{ section.settings.desc_color }};
    margin: 0 0 24px;
    line-height: 1.5;
  }

  /* ── Form layout ── */
  #{{ sid }} .er-form {
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.field_gap }}px;
  }
  #{{ sid }} .er-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ section.settings.field_gap }}px;
  }
  #{{ sid }} .er-field {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  /* ── Labels ── */
  #{{ sid }} .er-label {
    font-size: {{ section.settings.label_size }}px;
    font-weight: {{ section.settings.label_weight }};
    color: {{ section.settings.label_color }};
    display: flex;
    align-items: center;
    gap: 4px;
  }
  #{{ sid }} .er-required { color: {{ section.settings.accent_color }}; font-size: 14px; }
  #{{ sid }} .er-optional { color: {{ section.settings.desc_color }}; font-size: 11px; font-weight: 400; }

  /* ── Inputs ── */
  #{{ sid }} .er-input {
    width: 100%;
    padding: {{ section.settings.input_padding_v }}px {{ section.settings.input_padding_h }}px;
    font-size: {{ section.settings.input_font_size }}px;
    color: {{ section.settings.input_text_color }};
    background: {{ section.settings.input_bg }};
    border: {{ section.settings.input_border_width }}px solid {{ section.settings.input_border_color }};
    border-radius: {{ section.settings.input_radius }}px;
    box-sizing: border-box;
    outline: none;
    transition: border-color 0.15s, box-shadow 0.15s;
    font-family: inherit;
    appearance: none;
  }
  #{{ sid }} .er-input::placeholder { color: {{ section.settings.placeholder_color }}; }
  #{{ sid }} .er-input:focus {
    border-color: {{ section.settings.input_focus_border }};
    box-shadow: 0 0 0 3px {{ section.settings.input_focus_border }}22;
  }
  #{{ sid }} .er-input.is-invalid {
    border-color: {{ section.settings.error_color }};
    box-shadow: 0 0 0 3px {{ section.settings.error_color }}22;
  }
  #{{ sid }} .er-textarea {
    resize: vertical;
    min-height: 80px;
    line-height: 1.5;
  }

  /* ── Select ── */
  #{{ sid }} .er-select-wrap {
    position: relative;
  }
  #{{ sid }} .er-select {
    width: 100%;
    padding: {{ section.settings.input_padding_v }}px {{ section.settings.input_padding_h }}px;
    padding-right: 36px;
    font-size: {{ section.settings.input_font_size }}px;
    color: {{ section.settings.input_text_color }};
    background: {{ section.settings.input_bg }};
    border: {{ section.settings.input_border_width }}px solid {{ section.settings.input_border_color }};
    border-radius: {{ section.settings.input_radius }}px;
    box-sizing: border-box;
    outline: none;
    appearance: none;
    cursor: pointer;
    font-family: inherit;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  #{{ sid }} .er-select:focus {
    border-color: {{ section.settings.input_focus_border }};
    box-shadow: 0 0 0 3px {{ section.settings.input_focus_border }}22;
  }
  #{{ sid }} .er-select.is-invalid {
    border-color: {{ section.settings.error_color }};
    box-shadow: 0 0 0 3px {{ section.settings.error_color }}22;
  }
  #{{ sid }} .er-select-icon {
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
    color: {{ section.settings.desc_color }};
  }

  /* ── Validation errors ── */
  #{{ sid }} .er-error {
    font-size: 12px;
    color: {{ section.settings.error_color }};
    min-height: 16px;
    display: block;
    line-height: 1.3;
  }

  /* ── Button ── */
  #{{ sid }} .er-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    padding: {{ section.settings.btn_padding_v }}px {{ section.settings.btn_padding_h }}px;
    font-size: {{ section.settings.btn_font_size }}px;
    font-weight: {{ section.settings.btn_font_weight }};
    color: {{ section.settings.btn_text_color }};
    background: {{ section.settings.btn_bg }};
    border: 2px solid {{ section.settings.btn_bg }};
    border-radius: {{ section.settings.btn_radius }}px;
    cursor: pointer;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
    font-family: inherit;
    margin-top: 4px;
  }
  #{{ sid }} .er-btn:hover:not(:disabled) {
    background: {{ section.settings.btn_hover_bg }};
    border-color: {{ section.settings.btn_hover_bg }};
    color: {{ section.settings.btn_hover_text }};
  }
  #{{ sid }} .er-btn:disabled {
    opacity: 0.7;
    cursor: not-allowed;
  }
  #{{ sid }} .er-btn__spinner {
    display: none;
    width: 16px; height: 16px;
    border: 2px solid currentColor;
    border-top-color: transparent;
    border-radius: 50%;
    animation: er-spin 0.7s linear infinite;
    flex-shrink: 0;
  }
  #{{ sid }} .er-btn.is-loading .er-btn__label { opacity: 0.7; }
  #{{ sid }} .er-btn.is-loading .er-btn__spinner { display: block; }

  @keyframes er-spin { to { transform: rotate(360deg); } }

  /* ── Status messages ── */
  #{{ sid }} .er-status {
    display: none;
    align-items: center;
    gap: 10px;
    padding: 14px 16px;
    border-radius: {{ section.settings.input_radius }}px;
    font-size: 14px;
    font-weight: 500;
    line-height: 1.4;
  }
  #{{ sid }} .er-status--success {
    background: #e3edda;
    color: #2d5016;
  }
  #{{ sid }} .er-status--error {
    background: #fce8e8;
    color: #a32d2d;
  }
  #{{ sid }} .er-status.is-visible { display: flex; }

  /* ── Mobile ── */
  @media screen and (max-width: 749px) {
    #{{ sid }} .er-inner {
      grid-template-columns: 1fr;
      gap: {{ section.settings.col_gap | divided_by: 2 }}px;
    }
    #{{ sid }} .er-row {
      grid-template-columns: 1fr;
    }
    #{{ sid }} .er-title {
      font-size: {{ section.settings.title_size | times: 0.78 | round }}px;
    }
    #{{ sid }} .er-form-card {
      padding: {{ section.settings.card_padding | divided_by: 1.5 | round }}px;
    }
  }
</style>

<script>
(function() {
  var form    = document.getElementById('{{ sid }}-form');
  var btn     = document.getElementById('{{ sid }}-submit');
  var success = document.getElementById('{{ sid }}-success');
  var errBox  = document.getElementById('{{ sid }}-error');
  var webhook = {{ section.settings.webhook_url | json }};

  if (!form) return;

  /* ── Validation rules ── */
  var rules = {
    first_name:  { required: true,  minLength: 2,   label: {{ section.settings.label_firstname | default: 'First name' | json }} },
    last_name:   { required: true,  minLength: 2,   label: {{ section.settings.label_lastname  | default: 'Last name'  | json }} },
    email:       { required: true,  type: 'email',  label: {{ section.settings.label_email     | default: 'Email'      | json }} },
    phone:       { required: {{ section.settings.phone_required | json }}, type: 'phone', label: {{ section.settings.label_phone | default: 'Phone' | json }} },
    event:       { required: true,  label: {{ section.settings.label_event | default: 'Event' | json }} }
  };

  function validateField(name, value) {
    var rule = rules[name];
    if (!rule) return '';
    if (rule.required && !value.trim()) return rule.label + ' is required.';
    if (value.trim()) {
      if (rule.type === 'email' && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value))
        return 'Please enter a valid email address.';
      if (rule.type === 'phone' && !/^[\d\s\+\-\(\)]{6,20}$/.test(value.trim()))
        return 'Please enter a valid phone number.';
      if (rule.minLength && value.trim().length < rule.minLength)
        return rule.label + ' must be at least ' + rule.minLength + ' characters.';
    }
    return '';
  }

  function showFieldError(name, msg) {
    var el = form.querySelector('[data-error="' + name + '"]');
    var input = form.querySelector('[name="' + name + '"]');
    if (el) el.textContent = msg;
    if (input) {
      if (msg) input.classList.add('is-invalid');
      else input.classList.remove('is-invalid');
    }
  }

  function validateAll() {
    var valid = true;
    var data = new FormData(form);
    data.forEach(function(value, name) {
      var msg = validateField(name, value);
      showFieldError(name, msg);
      if (msg) valid = false;
    });
    /* Check phone if field exists and has value or is required */
    {%- if section.settings.show_phone -%}
    var phoneEl = form.querySelector('[name="phone"]');
    if (phoneEl) {
      var pMsg = validateField('phone', phoneEl.value);
      showFieldError('phone', pMsg);
      if (pMsg) valid = false;
    }
    {%- endif -%}
    return valid;
  }

  /* Live validation on blur */
  form.addEventListener('blur', function(e) {
    var el = e.target;
    if (!el.name) return;
    var msg = validateField(el.name, el.value);
    showFieldError(el.name, msg);
  }, true);

  /* Clear error on input */
  form.addEventListener('input', function(e) {
    var el = e.target;
    if (!el.name) return;
    var msg = validateField(el.name, el.value);
    showFieldError(el.name, msg);
  });

  form.addEventListener('submit', function(e) {
    e.preventDefault();
    success.classList.remove('is-visible');
    errBox.classList.remove('is-visible');

    if (!validateAll()) return;

    if (!webhook || webhook.trim() === '') {
      errBox.classList.add('is-visible');
      errBox.querySelector
      /* No webhook configured — show error */
      console.warn('[Event Registration] No webhook URL configured in section settings.');
      return;
    }

    /* Build payload */
    var data = {};
    new FormData(form).forEach(function(v, k) { data[k] = v; });
    data.submitted_at = new Date().toISOString();
    data.page_url     = window.location.href;

    btn.classList.add('is-loading');
    btn.disabled = true;

    fetch(webhook, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data)
    })
    .then(function(res) {
      if (!res.ok) throw new Error('HTTP ' + res.status);
      success.classList.add('is-visible');
      form.reset();
      /* Clear all errors */
      form.querySelectorAll('[data-error]').forEach(function(el) { el.textContent = ''; });
      form.querySelectorAll('.is-invalid').forEach(function(el) { el.classList.remove('is-invalid'); });
    })
    .catch(function(err) {
      console.error('[Event Registration] Webhook error:', err);
      errBox.classList.add('is-visible');
    })
    .finally(function() {
      btn.classList.remove('is-loading');
      btn.disabled = false;
    });
  });
})();

/* ── Event gallery hover ── */
(function() {
  var section = document.getElementById('{{ sid }}');
  if (!section) return;

  var list    = section.querySelector('[data-er-list]');
  var gallery = section.querySelector('[data-er-gallery]');
  if (!list || !gallery) return;

  var items  = Array.from(list.querySelectorAll('[data-er-item]'));
  var slides = Array.from(gallery.querySelectorAll('[data-er-slide]'));
  if (!items.length || !slides.length) return;

  function activate(index) {
    items.forEach(function(el) { el.classList.remove('is-active'); });
    slides.forEach(function(el) { el.classList.remove('is-active'); });
    var item  = items.find(function(el) { return el.dataset.erItem == index; });
    var slide = slides.find(function(el) { return el.dataset.erSlide == index; });
    if (item)  item.classList.add('is-active');
    if (slide) slide.classList.add('is-active');
  }

  /* Activate first item on load */
  activate(0);

  /* Hover to switch */
  items.forEach(function(item) {
    item.addEventListener('mouseenter', function() {
      activate(item.dataset.erItem);
    });
  });
})();
</script>

