{% comment %}
  Hero Slideshow Section
  - Multiple slides with desktop + mobile images (or video)
  - Adapt to image height option
  - Configurable text: heading, subheading, button
  - Per-slide text position (horizontal + vertical)
  - Per-slide font size, weight, color, line-break settings
  - Button active/inactive/border/color settings
  - Carousel indicators below the slider
{% endcomment %}

{%- liquid
  assign section_id = 'hero-slideshow-' | append: section.id
  assign autoplay = section.settings.autoplay
  assign autoplay_speed = section.settings.autoplay_speed | times: 1000
  assign adapt_height = section.settings.adapt_to_image
  assign slide_height = section.settings.slide_height
  assign show_indicators = section.settings.show_indicators
  assign show_arrows = section.settings.show_arrows
  assign indicator_style = section.settings.indicator_style
-%}

<section
  id="{{ section_id }}"
  class="hero-slideshow{% if adapt_height %} hero-slideshow--adapt{% endif %}"
  data-autoplay="{{ autoplay }}"
  data-speed="{{ autoplay_speed }}"
  aria-label="Hero slideshow"
>

  {%- comment %} ── Slides Track ── {%- endcomment %}
  <div class="hero-slideshow__track" role="list">
    {%- for block in section.blocks -%}
      {%- liquid
        assign is_active = false
        if forloop.first
          assign is_active = true
        endif

        assign h_align  = block.settings.text_horizontal_position
        assign v_align  = block.settings.text_vertical_position
        assign text_color = block.settings.heading_color
        assign sub_color  = block.settings.subheading_color
      -%}

      <div
        class="hero-slideshow__slide{% if is_active %} is-active{% endif %}"
        role="listitem"
        aria-hidden="{% unless is_active %}true{% else %}false{% endunless %}"
        {{ block.shopify_attributes }}
        style="
          {%- unless adapt_height -%}
            --slide-height: {{ slide_height }};
          {%- endunless -%}
        "
      >

        {%- comment %} ── Background Media ── {%- endcomment %}
        <div class="hero-slideshow__media">

          {%- comment %} Desktop image / video {%- endcomment %}
          {%- if block.settings.video_url != blank -%}
            {%- assign video_url = block.settings.video_url -%}
            {%- if video_url contains 'youtube.com' or video_url contains 'youtu.be' -%}
              {%- assign yt_id = video_url | split: 'v=' | last | split: '&' | first -%}
              {%- if video_url contains 'youtu.be/' -%}
                {%- assign yt_id = video_url | split: 'youtu.be/' | last | split: '?' | first -%}
              {%- endif -%}
              <iframe
                class="hero-slideshow__video hide-mobile"
                src="https://www.youtube.com/embed/{{ yt_id }}?autoplay=1&mute=1&loop=1&playlist={{ yt_id }}&controls=0&showinfo=0&rel=0"
                frameborder="0"
                allow="autoplay; encrypted-media"
                allowfullscreen
                aria-hidden="true"
              ></iframe>
            {%- elsif video_url contains 'vimeo.com' -%}
              {%- assign vimeo_id = video_url | split: 'vimeo.com/' | last | split: '?' | first -%}
              <iframe
                class="hero-slideshow__video hide-mobile"
                src="https://player.vimeo.com/video/{{ vimeo_id }}?autoplay=1&muted=1&loop=1&background=1"
                frameborder="0"
                allow="autoplay; fullscreen"
                aria-hidden="true"
              ></iframe>
            {%- else -%}
              <video
                class="hero-slideshow__video hide-mobile"
                src="{{ video_url }}"
                autoplay muted loop playsinline
                aria-hidden="true"
              ></video>
            {%- endif -%}
          {%- elsif block.settings.image != blank -%}
            {{
              block.settings.image
              | image_url: width: 2000
              | image_tag:
                class: 'hero-slideshow__img hide-mobile',
                loading: forloop.first | ternary: 'eager', 'lazy',
                fetchpriority: forloop.first | ternary: 'high', 'auto',
                sizes: '100vw',
                widths: '600, 900, 1200, 1600, 2000',
                alt: block.settings.image.alt | escape
            }}
          {%- else -%}
            <div class="hero-slideshow__placeholder hide-mobile" aria-hidden="true">
              {{ 'lifestyle-1' | placeholder_svg_tag: 'hero-slideshow__placeholder-svg' }}
            </div>
          {%- endif -%}

          {%- comment %} Mobile image {%- endcomment %}
          {%- if block.settings.mobile_image != blank -%}
            {{
              block.settings.mobile_image
              | image_url: width: 800
              | image_tag:
                class: 'hero-slideshow__img show-mobile-only',
                loading: forloop.first | ternary: 'eager', 'lazy',
                fetchpriority: forloop.first | ternary: 'high', 'auto',
                sizes: '100vw',
                widths: '400, 600, 800',
                alt: block.settings.mobile_image.alt | escape
            }}
          {%- elsif block.settings.image != blank -%}
            {%- comment %} Fallback to desktop image on mobile {%- endcomment %}
            {{
              block.settings.image
              | image_url: width: 800
              | image_tag:
                class: 'hero-slideshow__img show-mobile-only',
                loading: forloop.first | ternary: 'eager', 'lazy',
                sizes: '100vw',
                widths: '400, 600, 800',
                alt: block.settings.image.alt | escape
            }}
          {%- else -%}
            <div class="hero-slideshow__placeholder show-mobile-only" aria-hidden="true">
              {{ 'lifestyle-1' | placeholder_svg_tag: 'hero-slideshow__placeholder-svg' }}
            </div>
          {%- endif -%}

          {%- comment %} Overlay {%- endcomment %}
          {%- if block.settings.overlay_opacity > 0 -%}
            <div
              class="hero-slideshow__overlay"
              style="opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }}; background: {{ block.settings.overlay_color }};"
              aria-hidden="true"
            ></div>
          {%- endif -%}

        </div>
        {%- comment %} ── /Background Media ── {%- endcomment %}

        {%- comment %} ── Content ── {%- endcomment %}
        <div
          class="hero-slideshow__content hero-slideshow__content--h-{{ h_align }} hero-slideshow__content--v-{{ v_align }}"
        >
          <div class="hero-slideshow__content-inner">

            {%- comment %} Heading {%- endcomment %}
            {%- if block.settings.heading != blank -%}
              <h2
                class="hero-slideshow__heading"
                style="font-size: {{ block.settings.heading_size }}px; font-weight: {{ block.settings.heading_weight }}; color: {{ text_color }}; line-height: {{ block.settings.heading_line_height }};"
              >
                {%- if block.settings.heading_force_linebreak -%}
                  {{ block.settings.heading | newline_to_br }}
                {%- else -%}
                  {{ block.settings.heading | strip_newlines }}
                {%- endif -%}
              </h2>
            {%- endif -%}

            {%- comment %} Subheading {%- endcomment %}
            {%- if block.settings.subheading != blank -%}
              <p
                class="hero-slideshow__subheading"
                style="font-size: {{ block.settings.subheading_size }}px; font-weight: {{ block.settings.subheading_weight }}; color: {{ sub_color }}; line-height: {{ block.settings.subheading_line_height }};"
              >
                {%- if block.settings.subheading_force_linebreak -%}
                  {{ block.settings.subheading | newline_to_br }}
                {%- else -%}
                  {{ block.settings.subheading | strip_newlines }}
                {%- endif -%}
              </p>
            {%- endif -%}

            {%- comment %} Button {%- endcomment %}
            {%- if block.settings.button_label != blank -%}
              {%- assign btn_href = block.settings.button_url | default: '#' -%}
              <div class="hero-slideshow__btn-wrap">
                <a
                  href="{{ btn_href }}"
                  class="hero-slideshow__btn"
                  style="
                    --btn-bg:           {{ block.settings.btn_bg }};
                    --btn-text:         {{ block.settings.btn_text_color }};
                    --btn-border-color: {{ block.settings.btn_border_color }};
                    --btn-border-width: {{ block.settings.btn_border_width }}px;
                    --btn-radius:       {{ block.settings.btn_border_radius }}px;
                    --btn-hover-bg:     {{ block.settings.btn_hover_bg }};
                    --btn-hover-text:   {{ block.settings.btn_hover_text_color }};
                    --btn-hover-border: {{ block.settings.btn_hover_border_color }};
                  "
                >
                  {{ block.settings.button_label | escape }}
                </a>
              </div>
            {%- endif -%}

          </div>
        </div>
        {%- comment %} ── /Content ── {%- endcomment %}

      </div>
    {%- endfor -%}
  </div>
  {%- comment %} ── /Slides Track ── {%- endcomment %}

  {%- comment %} ── Arrow Controls ── {%- endcomment %}
  {%- if show_arrows and section.blocks.size > 1 -%}
    <button
      class="hero-slideshow__arrow hero-slideshow__arrow--prev"
      aria-label="{{ 'accessibility.previous_slide' | t | default: 'Previous slide' }}"
      type="button"
    >
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <path d="M12.5 15L7.5 10L12.5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
    <button
      class="hero-slideshow__arrow hero-slideshow__arrow--next"
      aria-label="{{ 'accessibility.next_slide' | t | default: 'Next slide' }}"
      type="button"
    >
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <path d="M7.5 5L12.5 10L7.5 15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  {%- endif -%}

  {%- comment %} ── Indicators (below slider) ── {%- endcomment %}
  {%- if show_indicators and section.blocks.size > 1 -%}
    <div
      class="hero-slideshow__indicators hero-slideshow__indicators--{{ indicator_style }}"
      role="tablist"
      aria-label="{{ 'accessibility.slideshow_indicators' | t | default: 'Slide indicators' }}"
      style="
        --ind-active-color:   {{ section.settings.indicator_active_color }};
        --ind-inactive-color: {{ section.settings.indicator_inactive_color }};
      "
    >
      {%- for block in section.blocks -%}
        <button
          class="hero-slideshow__indicator{% if forloop.first %} is-active{% endif %}"
          role="tab"
          aria-label="{{ 'accessibility.go_to_slide' | t: number: forloop.index | default: 'Go to slide ' | append: forloop.index }}"
          aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
          data-index="{{ forloop.index0 }}"
          type="button"
        ></button>
      {%- endfor -%}
    </div>
  {%- endif -%}

</section>

{%- comment %} ════════════════════════════════════════════════════════
    STYLES
════════════════════════════════════════════════════════ {%- endcomment %}
<style>
  #{{ section_id }} {
    --slide-height: {{ section.settings.slide_height }};
    position: relative;
    width: 100%;
    overflow: hidden;
    background: #f4f6f1;
  }

  /* ── Track ── */
  #{{ section_id }} .hero-slideshow__track {
    position: relative;
    width: 100%;
  }

  /* ── Slide ── */
  #{{ section_id }} .hero-slideshow__slide {
    position: relative;
    width: 100%;
    display: none;
    overflow: hidden;
  }
  #{{ section_id }} .hero-slideshow__slide.is-active {
    display: block;
  }

  /* ── Media ── */
  #{{ section_id }} .hero-slideshow__media {
    position: relative;
    width: 100%;
    {% unless adapt_height %}
      height: var(--slide-height);
    {% endunless %}
  }

  #{{ section_id }} .hero-slideshow__img {
    width: 100%;
    height: 100%;
    display: block;
    {% if adapt_height %}
      height: auto;
    {% else %}
      object-fit: cover;
      object-position: center;
    {% endif %}
  }

  #{{ section_id }} .hero-slideshow__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border: none;
  }

  #{{ section_id }} .hero-slideshow__placeholder {
    width: 100%;
    height: var(--slide-height, 520px);
    background: #e8ede3;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  #{{ section_id }} .hero-slideshow__placeholder-svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  /* ── Overlay ── */
  #{{ section_id }} .hero-slideshow__overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  /* ── Content positioning ── */
  #{{ section_id }} .hero-slideshow__content {
    position: absolute;
    inset: 0;
    display: flex;
    padding: 40px 60px;
    box-sizing: border-box;
  }

  /* Horizontal */
  #{{ section_id }} .hero-slideshow__content--h-left   { justify-content: flex-start; text-align: left; }
  #{{ section_id }} .hero-slideshow__content--h-center { justify-content: center;     text-align: center; }
  #{{ section_id }} .hero-slideshow__content--h-right  { justify-content: flex-end;   text-align: right; }

  /* Vertical */
  #{{ section_id }} .hero-slideshow__content--v-top    { align-items: flex-start; }
  #{{ section_id }} .hero-slideshow__content--v-middle { align-items: center; }
  #{{ section_id }} .hero-slideshow__content--v-bottom { align-items: flex-end; }

  #{{ section_id }} .hero-slideshow__content-inner {
    max-width: {{ section.settings.content_max_width }}px;
  }

  /* ── Heading ── */
  #{{ section_id }} .hero-slideshow__heading {
    margin: 0 0 12px;
    padding: 0;
    letter-spacing: -0.01em;
  }

  /* ── Subheading ── */
  #{{ section_id }} .hero-slideshow__subheading {
    margin: 0 0 28px;
    padding: 0;
  }

  /* ── Button ── */
  #{{ section_id }} .hero-slideshow__btn-wrap {
    margin-top: 4px;
  }
  #{{ section_id }} .hero-slideshow__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 32px;
    font-size: {{ section.settings.btn_font_size }}px;
    font-weight: {{ section.settings.btn_font_weight }};
    letter-spacing: 0.05em;
    text-decoration: none;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
    background-color: var(--btn-bg);
    color:            var(--btn-text);
    border:           var(--btn-border-width) solid var(--btn-border-color);
    border-radius:    var(--btn-radius);
  }
  #{{ section_id }} .hero-slideshow__btn:hover {
    background-color: var(--btn-hover-bg);
    color:            var(--btn-hover-text);
    border-color:     var(--btn-hover-border);
  }

  /* ── Arrows ── */
  #{{ section_id }} .hero-slideshow__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    background: rgba(255,255,255,0.85);
    border: none;
    border-radius: 50%;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #1a2e0a;
    transition: background 0.2s;
  }
  #{{ section_id }} .hero-slideshow__arrow:hover {
    background: #fff;
  }
  #{{ section_id }} .hero-slideshow__arrow--prev { left: 16px; }
  #{{ section_id }} .hero-slideshow__arrow--next { right: 16px; }

  /* ── Indicators ── */
  #{{ section_id }} .hero-slideshow__indicators {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 16px 0;
    background: {{ section.settings.indicators_bg }};
  }

  /* Dot style */
  #{{ section_id }} .hero-slideshow__indicators--dots .hero-slideshow__indicator {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: none;
    padding: 0;
    cursor: pointer;
    background: var(--ind-inactive-color);
    transition: background 0.2s, transform 0.2s;
  }
  #{{ section_id }} .hero-slideshow__indicators--dots .hero-slideshow__indicator.is-active {
    background: var(--ind-active-color);
    transform: scale(1.3);
  }

  /* Pill style */
  #{{ section_id }} .hero-slideshow__indicators--pills .hero-slideshow__indicator {
    width: 28px;
    height: 6px;
    border-radius: 3px;
    border: none;
    padding: 0;
    cursor: pointer;
    background: var(--ind-inactive-color);
    transition: background 0.2s, width 0.3s;
  }
  #{{ section_id }} .hero-slideshow__indicators--pills .hero-slideshow__indicator.is-active {
    background: var(--ind-active-color);
    width: 40px;
  }

  /* Line style */
  #{{ section_id }} .hero-slideshow__indicators--lines .hero-slideshow__indicator {
    width: 32px;
    height: 2px;
    border: none;
    padding: 0;
    cursor: pointer;
    background: var(--ind-inactive-color);
    transition: background 0.2s;
  }
  #{{ section_id }} .hero-slideshow__indicators--lines .hero-slideshow__indicator.is-active {
    background: var(--ind-active-color);
  }

  /* ── Visibility helpers ── */
  @media screen and (max-width: 749px) {
    .hide-mobile      { display: none !important; }
    .show-mobile-only { display: block !important; }

    #{{ section_id }} .hero-slideshow__content {
      padding: 24px 20px;
    }
    #{{ section_id }} .hero-slideshow__arrow {
      width: 36px;
      height: 36px;
    }
  }
  @media screen and (min-width: 750px) {
    .show-mobile-only { display: none !important; }
  }

  /* ── Fade transition ── */
  #{{ section_id }} .hero-slideshow__slide {
    opacity: 0;
    transition: opacity 0.5s ease;
  }
  #{{ section_id }} .hero-slideshow__slide.is-active {
    opacity: 1;
  }
</style>

{%- comment %} ════════════════════════════════════════════════════════
    JAVASCRIPT
════════════════════════════════════════════════════════ {%- endcomment %}
<script>
(function() {
  const section   = document.getElementById('{{ section_id }}');
  if (!section) return;

  const slides     = Array.from(section.querySelectorAll('.hero-slideshow__slide'));
  const indicators = Array.from(section.querySelectorAll('.hero-slideshow__indicator'));
  const prevBtn    = section.querySelector('.hero-slideshow__arrow--prev');
  const nextBtn    = section.querySelector('.hero-slideshow__arrow--next');
  const autoplay   = section.dataset.autoplay === 'true';
  const speed      = parseInt(section.dataset.speed, 10) || 5000;

  let current = 0;
  let timer   = null;

  function goTo(index) {
    slides[current].classList.remove('is-active');
    slides[current].setAttribute('aria-hidden', 'true');
    if (indicators[current]) {
      indicators[current].classList.remove('is-active');
      indicators[current].setAttribute('aria-selected', 'false');
    }

    current = (index + slides.length) % slides.length;

    slides[current].classList.add('is-active');
    slides[current].setAttribute('aria-hidden', 'false');
    if (indicators[current]) {
      indicators[current].classList.add('is-active');
      indicators[current].setAttribute('aria-selected', 'true');
    }
  }

  function next() { goTo(current + 1); }
  function prev() { goTo(current - 1); }

  function startAutoplay() {
    if (!autoplay || slides.length < 2) return;
    timer = setInterval(next, speed);
  }

  function stopAutoplay() {
    if (timer) { clearInterval(timer); timer = null; }
  }

  // Arrow buttons
  if (prevBtn) prevBtn.addEventListener('click', function() { stopAutoplay(); prev(); startAutoplay(); });
  if (nextBtn) nextBtn.addEventListener('click', function() { stopAutoplay(); next(); startAutoplay(); });

  // Indicators
  indicators.forEach(function(btn) {
    btn.addEventListener('click', function() {
      stopAutoplay();
      goTo(parseInt(btn.dataset.index, 10));
      startAutoplay();
    });
  });

  // Keyboard
  section.addEventListener('keydown', function(e) {
    if (e.key === 'ArrowLeft')  { stopAutoplay(); prev(); startAutoplay(); }
    if (e.key === 'ArrowRight') { stopAutoplay(); next(); startAutoplay(); }
  });

  // Pause on hover
  section.addEventListener('mouseenter', stopAutoplay);
  section.addEventListener('mouseleave', startAutoplay);

  // Touch / swipe
  let touchStartX = 0;
  section.addEventListener('touchstart', function(e) { touchStartX = e.touches[0].clientX; }, { passive: true });
  section.addEventListener('touchend',   function(e) {
    const diff = touchStartX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 50) {
      stopAutoplay();
      diff > 0 ? next() : prev();
      startAutoplay();
    }
  }, { passive: true });

  startAutoplay();
})();
</script>

{% schema %}
{
  "name": "Hero Slideshow",
  "tag": "section",
  "class": "hero-slideshow-section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "header",
      "content": "Slideshow"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Auto-rotate slides",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Change slides every",
      "min": 2,
      "max": 15,
      "step": 1,
      "unit": "s",
      "default": 5
    },
    {
      "type": "header",
      "content": "Height"
    },
    {
      "type": "checkbox",
      "id": "adapt_to_image",
      "label": "Adapt to image height",
      "info": "When enabled the slide grows/shrinks to fit the image naturally. When disabled a fixed height is used.",
      "default": false
    },
    {
      "type": "select",
      "id": "slide_height",
      "label": "Fixed slide height",
      "info": "Used when 'Adapt to image' is off",
      "options": [
        { "value": "300px",  "label": "Small — 300px" },
        { "value": "420px",  "label": "Medium — 420px" },
        { "value": "560px",  "label": "Large — 560px" },
        { "value": "680px",  "label": "Extra large — 680px" },
        { "value": "100vh",  "label": "Full screen height" }
      ],
      "default": "560px"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "Content max width (px)",
      "min": 200,
      "max": 900,
      "step": 20,
      "default": 500
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "checkbox",
      "id": "show_indicators",
      "label": "Show slide indicators",
      "default": true
    },
    {
      "type": "select",
      "id": "indicator_style",
      "label": "Indicator style",
      "options": [
        { "value": "dots",  "label": "Dots" },
        { "value": "pills", "label": "Pills" },
        { "value": "lines", "label": "Lines" }
      ],
      "default": "pills"
    },
    {
      "type": "color",
      "id": "indicator_active_color",
      "label": "Active indicator color",
      "default": "#1a2e0a"
    },
    {
      "type": "color",
      "id": "indicator_inactive_color",
      "label": "Inactive indicator color",
      "default": "#b8c4ad"
    },
    {
      "type": "color",
      "id": "indicators_bg",
      "label": "Indicators area background",
      "default": "#ffffff"
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
