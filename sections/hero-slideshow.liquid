{% comment %}
  Hero Slideshow Section
  - Multiple slides with desktop + mobile images (or video)
  - Adapt to image height option
  - Configurable text: heading, subheading, button
  - Per-slide text position — separate desktop & mobile
  - Per-slide font size, weight, color, line-break settings
  - Button active/inactive/border/color settings
  - Carousel indicators + arrows below the slider (desktop & mobile)
{% endcomment %}

{%- liquid
  assign section_id      = 'hero-slideshow-' | append: section.id
  assign autoplay        = section.settings.autoplay
  assign autoplay_speed  = section.settings.autoplay_speed | times: 1000
  assign adapt_height    = section.settings.adapt_to_image
  assign slide_height    = section.settings.slide_height
  assign show_indicators = section.settings.show_indicators
  assign show_arrows     = section.settings.show_arrows
  assign indicator_style = section.settings.indicator_style
-%}

<section
  id="{{ section_id }}"
  class="hero-slideshow{% if adapt_height %} hero-slideshow--adapt{% endif %}"
  data-autoplay="{{ autoplay }}"
  data-speed="{{ autoplay_speed }}"
  aria-label="Hero slideshow"
>

  {%- comment %} ── Slides Track ── {%- endcomment %}
  <div class="hero-slideshow__track" role="list">
    {%- for block in section.blocks -%}

      {%- liquid
        assign is_active  = false
        if forloop.first
          assign is_active = true
        endif
        assign text_color = block.settings.heading_color
        assign sub_color  = block.settings.subheading_color
      -%}

      {%- comment %} Desktop position → flex values ── {%- endcomment %}
      {%- assign h_align = block.settings.text_horizontal_position -%}
      {%- assign v_align = block.settings.text_vertical_position -%}
      {%- if h_align == 'center' -%}{%- assign h_justify = 'center' -%}{%- assign h_text = 'center' -%}
      {%- elsif h_align == 'right' -%}{%- assign h_justify = 'flex-end' -%}{%- assign h_text = 'right' -%}
      {%- else -%}{%- assign h_justify = 'flex-start' -%}{%- assign h_text = 'left' -%}
      {%- endif -%}
      {%- if v_align == 'top' -%}{%- assign v_items = 'flex-start' -%}
      {%- elsif v_align == 'bottom' -%}{%- assign v_items = 'flex-end' -%}
      {%- else -%}{%- assign v_items = 'center' -%}
      {%- endif -%}

      {%- comment %} Mobile position → flex values ── {%- endcomment %}
      {%- assign mh_align = block.settings.mobile_text_horizontal_position -%}
      {%- assign mv_align = block.settings.mobile_text_vertical_position -%}
      {%- if mh_align == 'center' -%}{%- assign mh_justify = 'center' -%}{%- assign mh_text = 'center' -%}
      {%- elsif mh_align == 'right' -%}{%- assign mh_justify = 'flex-end' -%}{%- assign mh_text = 'right' -%}
      {%- else -%}{%- assign mh_justify = 'flex-start' -%}{%- assign mh_text = 'left' -%}
      {%- endif -%}
      {%- if mv_align == 'top' -%}{%- assign mv_items = 'flex-start' -%}
      {%- elsif mv_align == 'bottom' -%}{%- assign mv_items = 'flex-end' -%}
      {%- else -%}{%- assign mv_items = 'center' -%}
      {%- endif -%}

      <div
        class="hero-slideshow__slide{% if is_active %} is-active{% endif %}"
        role="listitem"
        aria-hidden="{% unless is_active %}true{% else %}false{% endunless %}"
        {{ block.shopify_attributes }}
        style="{% unless adapt_height %}--slide-height: {{ slide_height }};{% endunless %}"
      >

        {%- comment %} ── Background Media ── {%- endcomment %}
        <div class="hero-slideshow__media">

          {%- comment %} Desktop image / video {%- endcomment %}
          {%- if block.settings.video_url != blank -%}
            {%- assign video_url = block.settings.video_url -%}
            {%- if video_url contains 'youtube.com' or video_url contains 'youtu.be' -%}
              {%- assign yt_id = video_url | split: 'v=' | last | split: '&' | first -%}
              {%- if video_url contains 'youtu.be/' -%}{%- assign yt_id = video_url | split: 'youtu.be/' | last | split: '?' | first -%}{%- endif -%}
              <iframe class="hero-slideshow__video hero-slideshow__desktop-only"
                src="https://www.youtube.com/embed/{{ yt_id }}?autoplay=1&mute=1&loop=1&playlist={{ yt_id }}&controls=0&rel=0"
                frameborder="0" allow="autoplay; encrypted-media" allowfullscreen aria-hidden="true"></iframe>
            {%- elsif video_url contains 'vimeo.com' -%}
              {%- assign vimeo_id = video_url | split: 'vimeo.com/' | last | split: '?' | first -%}
              <iframe class="hero-slideshow__video hero-slideshow__desktop-only"
                src="https://player.vimeo.com/video/{{ vimeo_id }}?autoplay=1&muted=1&loop=1&background=1"
                frameborder="0" allow="autoplay; fullscreen" aria-hidden="true"></iframe>
            {%- else -%}
              <video class="hero-slideshow__video hero-slideshow__desktop-only"
                src="{{ video_url }}" autoplay muted loop playsinline aria-hidden="true"></video>
            {%- endif -%}
          {%- elsif block.settings.image != blank -%}
            {{
              block.settings.image
              | image_url: width: 2000
              | image_tag:
                class: 'hero-slideshow__img hero-slideshow__desktop-only',
                loading: forloop.first | ternary: 'eager', 'lazy',
                fetchpriority: forloop.first | ternary: 'high', 'auto',
                sizes: '100vw',
                widths: '600, 900, 1200, 1600, 2000',
                alt: block.settings.image.alt | escape
            }}
          {%- else -%}
            <div class="hero-slideshow__placeholder hero-slideshow__desktop-only" aria-hidden="true">
              {{ 'lifestyle-1' | placeholder_svg_tag: 'hero-slideshow__placeholder-svg' }}
            </div>
          {%- endif -%}

          {%- comment %} Mobile image {%- endcomment %}
          {%- if block.settings.mobile_image != blank -%}
            {{
              block.settings.mobile_image
              | image_url: width: 800
              | image_tag:
                class: 'hero-slideshow__img hero-slideshow__mobile-only',
                loading: forloop.first | ternary: 'eager', 'lazy',
                sizes: '100vw',
                widths: '400, 600, 800',
                alt: block.settings.mobile_image.alt | escape
            }}
          {%- elsif block.settings.image != blank -%}
            {{
              block.settings.image
              | image_url: width: 800
              | image_tag:
                class: 'hero-slideshow__img hero-slideshow__mobile-only',
                loading: forloop.first | ternary: 'eager', 'lazy',
                sizes: '100vw',
                widths: '400, 600, 800',
                alt: block.settings.image.alt | escape
            }}
          {%- else -%}
            <div class="hero-slideshow__placeholder hero-slideshow__mobile-only" aria-hidden="true">
              {{ 'lifestyle-1' | placeholder_svg_tag: 'hero-slideshow__placeholder-svg' }}
            </div>
          {%- endif -%}

          {%- comment %} Overlay {%- endcomment %}
          {%- if block.settings.overlay_opacity > 0 -%}
            <div class="hero-slideshow__overlay"
              style="opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }}; background: {{ block.settings.overlay_color }};"
              aria-hidden="true"></div>
          {%- endif -%}

        </div>
        {%- comment %} ── /Background Media ── {%- endcomment %}

        {%- comment %} ── Content ── {%- endcomment %}
        <div
          class="hero-slideshow__content"
          style="justify-content: {{ h_justify }}; align-items: {{ v_items }};"
          data-desk-justify="{{ h_justify }}"
          data-desk-items="{{ v_items }}"
          data-mob-justify="{{ mh_justify }}"
          data-mob-items="{{ mv_items }}"
        >
          <div
            class="hero-slideshow__content-inner"
            style="text-align: {{ h_text }};"
            data-desk-text="{{ h_text }}"
            data-mob-text="{{ mh_text }}"
          >

            {%- if block.settings.heading != blank -%}
              <h2 class="hero-slideshow__heading"
                style="font-size: {{ block.settings.heading_size }}px; font-weight: {{ block.settings.heading_weight }}; color: {{ text_color }}; line-height: {{ block.settings.heading_line_height }};">
                {%- if block.settings.heading_force_linebreak -%}
                  {{ block.settings.heading | newline_to_br }}
                {%- else -%}
                  {{ block.settings.heading | strip_newlines }}
                {%- endif -%}
              </h2>
            {%- endif -%}

            {%- if block.settings.subheading != blank -%}
              <p class="hero-slideshow__subheading"
                style="font-size: {{ block.settings.subheading_size }}px; font-weight: {{ block.settings.subheading_weight }}; color: {{ sub_color }}; line-height: {{ block.settings.subheading_line_height }};">
                {%- if block.settings.subheading_force_linebreak -%}
                  {{ block.settings.subheading | newline_to_br }}
                {%- else -%}
                  {{ block.settings.subheading | strip_newlines }}
                {%- endif -%}
              </p>
            {%- endif -%}

            {%- if block.settings.button_label != blank -%}
              {%- assign btn_href = block.settings.button_url | default: '#' -%}
              <div class="hero-slideshow__btn-wrap" style="justify-content: {{ h_justify }};"
                data-desk-justify="{{ h_justify }}" data-mob-justify="{{ mh_justify }}">
                <a href="{{ btn_href }}" class="hero-slideshow__btn"
                  style="
                    --btn-bg: {{ block.settings.btn_bg }};
                    --btn-text: {{ block.settings.btn_text_color }};
                    --btn-border-color: {{ block.settings.btn_border_color }};
                    --btn-border-width: {{ block.settings.btn_border_width }}px;
                    --btn-radius: {{ block.settings.btn_border_radius }}px;
                    --btn-hover-bg: {{ block.settings.btn_hover_bg }};
                    --btn-hover-text: {{ block.settings.btn_hover_text_color }};
                    --btn-hover-border: {{ block.settings.btn_hover_border_color }};
                  "
                >{{ block.settings.button_label | escape }}</a>
              </div>
            {%- endif -%}

          </div>
        </div>
        {%- comment %} ── /Content ── {%- endcomment %}

      </div>
    {%- endfor -%}
  </div>
  {%- comment %} ── /Slides Track ── {%- endcomment %}

  {%- comment %} ── Navigation Bar — shown on BOTH desktop & mobile ── {%- endcomment %}
  {%- if section.blocks.size > 1 -%}
    <div
      class="hero-slideshow__nav-bar"
      style="
        --ind-active-color:   {{ section.settings.indicator_active_color }};
        --ind-inactive-color: {{ section.settings.indicator_inactive_color }};
        --nav-bar-height:     {{ section.settings.indicator_bar_height }}px;
        background:           {{ section.settings.indicators_bg }};
      "
    >

      {%- if show_arrows -%}
        <button class="hero-slideshow__arrow hero-slideshow__arrow--prev"
          aria-label="Previous slide" type="button">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M12.5 15L7.5 10L12.5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      {%- else -%}
        <span class="hero-slideshow__nav-spacer"></span>
      {%- endif -%}

      {%- if show_indicators -%}
        <div class="hero-slideshow__indicators hero-slideshow__indicators--{{ indicator_style }}"
          role="tablist" aria-label="Slide indicators">
          {%- for block in section.blocks -%}
            <button
              class="hero-slideshow__indicator{% if forloop.first %} is-active{% endif %}"
              role="tab"
              aria-label="Go to slide {{ forloop.index }}"
              aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
              data-index="{{ forloop.index0 }}"
              type="button"
            ></button>
          {%- endfor -%}
        </div>
      {%- else -%}
        <span class="hero-slideshow__nav-spacer"></span>
      {%- endif -%}

      {%- if show_arrows -%}
        <button class="hero-slideshow__arrow hero-slideshow__arrow--next"
          aria-label="Next slide" type="button">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M7.5 5L12.5 10L7.5 15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      {%- else -%}
        <span class="hero-slideshow__nav-spacer"></span>
      {%- endif -%}

    </div>
  {%- endif -%}

</section>

<style>
  /* ── Section shell ── */
  #{{ section_id }} {
    --slide-height: {{ section.settings.slide_height }};
    position: relative;
    width: 100%;
    background: #f4f6f1;
  }

  /* ── Slide ── */
  #{{ section_id }} .hero-slideshow__slide {
    position: relative;
    width: 100%;
    display: none;
    overflow: hidden;
    opacity: 0;
    transition: opacity 0.5s ease;
  }
  #{{ section_id }} .hero-slideshow__slide.is-active {
    display: block;
    opacity: 1;
  }

  /* ── Media ── */
  #{{ section_id }} .hero-slideshow__media {
    position: relative;
    width: 100%;
    {% unless adapt_height %}height: var(--slide-height);{% endunless %}
  }
  #{{ section_id }} .hero-slideshow__img {
    width: 100%;
    display: block;
    {% if adapt_height %}height: auto;{% else %}height: 100%; object-fit: cover; object-position: center;{% endif %}
  }
  #{{ section_id }} .hero-slideshow__video {
    width: 100%; height: 100%;
    object-fit: cover; display: block; border: none;
  }
  #{{ section_id }} .hero-slideshow__placeholder {
    width: 100%;
    height: var(--slide-height, 520px);
    background: #e8ede3;
    display: flex; align-items: center; justify-content: center;
  }
  #{{ section_id }} .hero-slideshow__placeholder-svg {
    width: 60%; height: 60%; opacity: 0.3;
  }

  /* ── Responsive visibility ── */
  #{{ section_id }} .hero-slideshow__desktop-only { display: block; }
  #{{ section_id }} .hero-slideshow__mobile-only  { display: none;  }

  @media screen and (max-width: 749px) {
    #{{ section_id }} .hero-slideshow__desktop-only { display: none  !important; }
    #{{ section_id }} .hero-slideshow__mobile-only  { display: block !important; }
  }

  /* ── Overlay ── */
  #{{ section_id }} .hero-slideshow__overlay {
    position: absolute; inset: 0; pointer-events: none;
  }

  /* ── Content ── */
  #{{ section_id }} .hero-slideshow__content {
    position: absolute;
    inset: 0;
    display: flex;
    padding: 40px 60px;
    box-sizing: border-box;
  }
  #{{ section_id }} .hero-slideshow__content-inner {
    max-width: {{ section.settings.content_max_width }}px;
    width: 100%;
  }
  #{{ section_id }} .hero-slideshow__heading {
    margin: 0 0 12px; padding: 0; letter-spacing: -0.01em;
  }
  #{{ section_id }} .hero-slideshow__subheading {
    margin: 0 0 28px; padding: 0;
  }

  /* ── Button ── */
  #{{ section_id }} .hero-slideshow__btn-wrap {
    display: flex; margin-top: 4px;
  }
  #{{ section_id }} .hero-slideshow__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 32px;
    font-size: {{ section.settings.btn_font_size }}px;
    font-weight: {{ section.settings.btn_font_weight }};
    letter-spacing: 0.05em;
    text-decoration: none;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
    background-color: var(--btn-bg);
    color:            var(--btn-text);
    border:           var(--btn-border-width) solid var(--btn-border-color);
    border-radius:    var(--btn-radius);
  }
  #{{ section_id }} .hero-slideshow__btn:hover {
    background-color: var(--btn-hover-bg);
    color:            var(--btn-hover-text);
    border-color:     var(--btn-hover-border);
  }

  /* ── Nav bar — arrows + indicators ── */
  #{{ section_id }} .hero-slideshow__nav-bar {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    height: var(--nav-bar-height, 56px);
    padding: 0 16px;
    /* NOT hidden on mobile — always visible */
  }
  #{{ section_id }} .hero-slideshow__nav-spacer {
    width: 36px; flex-shrink: 0; display: block;
  }

  /* ── Arrows ── */
  #{{ section_id }} .hero-slideshow__arrow {
    flex-shrink: 0;
    background: transparent;
    border: none;
    border-radius: 50%;
    width: 36px; height: 36px;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    color: #1a2e0a;
    transition: background 0.2s;
    padding: 0;
  }
  #{{ section_id }} .hero-slideshow__arrow:hover {
    background: rgba(0,0,0,0.06);
  }

  /* ── Indicators ── */
  #{{ section_id }} .hero-slideshow__indicators {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  /* Dot */
  #{{ section_id }} .hero-slideshow__indicators--dots .hero-slideshow__indicator {
    width: 10px; height: 10px; border-radius: 50%;
    border: none; padding: 0; cursor: pointer;
    background: var(--ind-inactive-color);
    transition: background 0.2s, transform 0.2s;
  }
  #{{ section_id }} .hero-slideshow__indicators--dots .hero-slideshow__indicator.is-active {
    background: var(--ind-active-color); transform: scale(1.3);
  }

  /* Pill */
  #{{ section_id }} .hero-slideshow__indicators--pills .hero-slideshow__indicator {
    width: 28px; height: 6px; border-radius: 3px;
    border: none; padding: 0; cursor: pointer;
    background: var(--ind-inactive-color);
    transition: background 0.2s, width 0.3s;
  }
  #{{ section_id }} .hero-slideshow__indicators--pills .hero-slideshow__indicator.is-active {
    background: var(--ind-active-color); width: 40px;
  }

  /* Line */
  #{{ section_id }} .hero-slideshow__indicators--lines .hero-slideshow__indicator {
    width: 32px; height: 2px;
    border: none; padding: 0; cursor: pointer;
    background: var(--ind-inactive-color);
    transition: background 0.2s;
  }
  #{{ section_id }} .hero-slideshow__indicators--lines .hero-slideshow__indicator.is-active {
    background: var(--ind-active-color);
  }

  /* ── Mobile tweaks ── */
  @media screen and (max-width: 749px) {
    #{{ section_id }} .hero-slideshow__content {
      padding: 20px 16px;
    }
    #{{ section_id }} .hero-slideshow__arrow {
      width: 32px; height: 32px;
    }
    /* Slightly smaller pills/dots on mobile for compact nav */
    #{{ section_id }} .hero-slideshow__indicators--pills .hero-slideshow__indicator {
      width: 20px; height: 5px;
    }
    #{{ section_id }} .hero-slideshow__indicators--pills .hero-slideshow__indicator.is-active {
      width: 32px;
    }
    #{{ section_id }} .hero-slideshow__indicators--dots .hero-slideshow__indicator {
      width: 8px; height: 8px;
    }
  }
</style>

<script>
(function () {
  var section    = document.getElementById('{{ section_id }}');
  if (!section) return;

  var slides     = Array.from(section.querySelectorAll('.hero-slideshow__slide'));
  var indicators = Array.from(section.querySelectorAll('.hero-slideshow__indicator'));
  var prevBtn    = section.querySelector('.hero-slideshow__arrow--prev');
  var nextBtn    = section.querySelector('.hero-slideshow__arrow--next');
  var autoplay   = section.dataset.autoplay === 'true';
  var speed      = parseInt(section.dataset.speed, 10) || 5000;
  var current    = 0;
  var timer      = null;

  function goTo(index) {
    slides[current].classList.remove('is-active');
    slides[current].setAttribute('aria-hidden', 'true');
    if (indicators[current]) {
      indicators[current].classList.remove('is-active');
      indicators[current].setAttribute('aria-selected', 'false');
    }
    current = (index + slides.length) % slides.length;
    slides[current].classList.add('is-active');
    slides[current].setAttribute('aria-hidden', 'false');
    if (indicators[current]) {
      indicators[current].classList.add('is-active');
      indicators[current].setAttribute('aria-selected', 'true');
    }
  }

  function next() { goTo(current + 1); }
  function prev() { goTo(current - 1); }
  function startAutoplay() { if (autoplay && slides.length > 1) timer = setInterval(next, speed); }
  function stopAutoplay()  { if (timer) { clearInterval(timer); timer = null; } }

  if (prevBtn) prevBtn.addEventListener('click', function () { stopAutoplay(); prev(); startAutoplay(); });
  if (nextBtn) nextBtn.addEventListener('click', function () { stopAutoplay(); next(); startAutoplay(); });

  indicators.forEach(function (btn) {
    btn.addEventListener('click', function () {
      stopAutoplay();
      goTo(parseInt(btn.dataset.index, 10));
      startAutoplay();
    });
  });

  section.addEventListener('keydown', function (e) {
    if (e.key === 'ArrowLeft')  { stopAutoplay(); prev(); startAutoplay(); }
    if (e.key === 'ArrowRight') { stopAutoplay(); next(); startAutoplay(); }
  });

  section.addEventListener('mouseenter', stopAutoplay);
  section.addEventListener('mouseleave', startAutoplay);

  var touchStartX = 0;
  section.addEventListener('touchstart', function (e) { touchStartX = e.touches[0].clientX; }, { passive: true });
  section.addEventListener('touchend',   function (e) {
    var diff = touchStartX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 50) { stopAutoplay(); diff > 0 ? next() : prev(); startAutoplay(); }
  }, { passive: true });

  /* ── Position swap: desktop ↔ mobile ── */
  function applyPositions() {
    var mob = window.innerWidth < 750;
    slides.forEach(function (slide) {
      var content = slide.querySelector('.hero-slideshow__content');
      var inner   = slide.querySelector('.hero-slideshow__content-inner');
      var btnWrap = slide.querySelector('.hero-slideshow__btn-wrap');
      if (!content || !inner) return;

      if (mob) {
        content.style.justifyContent = content.dataset.mobJustify || content.dataset.deskJustify;
        content.style.alignItems     = content.dataset.mobItems   || content.dataset.deskItems;
        inner.style.textAlign        = inner.dataset.mobText      || inner.dataset.deskText;
        if (btnWrap) btnWrap.style.justifyContent = btnWrap.dataset.mobJustify || btnWrap.dataset.deskJustify;
      } else {
        content.style.justifyContent = content.dataset.deskJustify;
        content.style.alignItems     = content.dataset.deskItems;
        inner.style.textAlign        = inner.dataset.deskText;
        if (btnWrap) btnWrap.style.justifyContent = btnWrap.dataset.deskJustify;
      }
    });
  }

  applyPositions();
  window.addEventListener('resize', applyPositions);

  startAutoplay();
})();
</script>

{% schema %}
{
  "name": "Hero Slideshow",
  "tag": "section",
  "class": "hero-slideshow-section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "header",
      "content": "Slideshow"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Auto-rotate slides",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Change slides every",
      "min": 2,
      "max": 15,
      "step": 1,
      "unit": "s",
      "default": 5
    },
    {
      "type": "header",
      "content": "Height"
    },
    {
      "type": "checkbox",
      "id": "adapt_to_image",
      "label": "Adapt to image height",
