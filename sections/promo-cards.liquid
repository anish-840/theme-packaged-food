{% comment %}
  Promo Cards Section
  - Up to 3 configurable cards side by side
  - Each card: background color, image, label text, heading, button
  - Full settings for colors, fonts, button styles, sizing
  - Mobile: stacks vertically
{% endcomment %}

{%- assign section_id = 'promo-cards-' | append: section.id -%}

<section id="{{ section_id }}" class="promo-cards">
  <div class="promo-cards__grid">
    {%- for block in section.blocks -%}
      {%- assign img        = block.settings.image -%}
      {%- assign bg_color   = block.settings.card_bg -%}
      {%- assign label      = block.settings.label -%}
      {%- assign heading    = block.settings.heading -%}
      {%- assign btn_label  = block.settings.button_label -%}
      {%- assign btn_url    = block.settings.button_url | default: '#' -%}

      <div
        class="promo-card"
        style="background-color: {{ bg_color }}; border-radius: {{ section.settings.card_radius }}px;"
        {{ block.shopify_attributes }}
      >

        {%- comment %} Image ── {%- endcomment %}
        <div class="promo-card__media">
          {%- if img != blank -%}
            {{
              img
              | image_url: width: 1000
              | image_tag:
                class: 'promo-card__img',
                loading: 'lazy',
                widths: '400, 600, 800, 1000',
                sizes: '(max-width: 749px) 100vw, 33vw',
                alt: img.alt | default: heading | escape
            }}
          {%- else -%}
            <div class="promo-card__img-placeholder">
              {{ 'image' | placeholder_svg_tag: 'promo-card__placeholder-svg' }}
            </div>
          {%- endif -%}
        </div>

        {%- comment %} Content ── {%- endcomment %}
        <div class="promo-card__content">
          {%- if label != blank -%}
            <p
              class="promo-card__label"
              style="
                font-size: {{ section.settings.label_size }}px;
                font-weight: {{ section.settings.label_weight }};
                color: {{ block.settings.label_color }};
              "
            >{{ label | escape }}</p>
          {%- endif -%}

          {%- if heading != blank -%}
            <h2
              class="promo-card__heading"
              style="
                font-size: {{ section.settings.heading_size }}px;
                font-weight: {{ section.settings.heading_weight }};
                color: {{ block.settings.heading_color }};
                line-height: {{ section.settings.heading_line_height }};
              "
            >{{ heading | escape }}</h2>
          {%- endif -%}

          {%- if btn_label != blank -%}
            <a
              href="{{ btn_url }}"
              class="promo-card__btn"
              style="
                background-color: {{ block.settings.btn_bg }};
                color: {{ block.settings.btn_text }};
                border: {{ section.settings.btn_border_width }}px solid {{ block.settings.btn_border_color }};
                border-radius: {{ section.settings.btn_radius }}px;
                font-size: {{ section.settings.btn_font_size }}px;
                font-weight: {{ section.settings.btn_font_weight }};
                --btn-hover-bg: {{ block.settings.btn_hover_bg }};
                --btn-hover-text: {{ block.settings.btn_hover_text }};
                --btn-hover-border: {{ block.settings.btn_hover_border }};
              "
            >{{ btn_label | escape }}</a>
          {%- endif -%}
        </div>

      </div>
    {%- endfor -%}
  </div>
</section>

<style>
  #{{ section_id }} {
    padding: {{ section.settings.section_padding_top }}px {{ section.settings.section_padding_x }}px {{ section.settings.section_padding_bottom }}px;
    background: {{ section.settings.section_bg }};
  }

  #{{ section_id }} .promo-cards__grid {
    display: grid;
    grid-template-columns: repeat({{ section.blocks.size | at_most: 3 }}, 1fr);
    gap: {{ section.settings.card_gap }}px;
  }

  #{{ section_id }} .promo-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    position: relative;
  }

  /* ── Image ── */
  #{{ section_id }} .promo-card__media {
    width: 100%;
    box-sizing: border-box;
    padding-left: {{ section.settings.image_padding_x }}px;
    padding-right: {{ section.settings.image_padding_x }}px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  #{{ section_id }} .promo-card__img {
    display: block;
    width: 100%;
    max-width: 100%;
    {% if section.settings.adapt_to_image %}
      height: auto;
      max-height: {{ section.settings.image_height }}px;
      object-fit: contain;
    {% else %}
      height: {{ section.settings.image_height }}px;
      object-fit: cover;
      object-position: center;
    {% endif %}
    transition: transform 0.4s ease;
  }
  #{{ section_id }} .promo-card:hover .promo-card__img {
    transform: scale(1.03);
  }
  #{{ section_id }} .promo-card__img-placeholder {
    width: 100%;
    height: {{ section.settings.image_height }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.2;
  }
  #{{ section_id }} .promo-card__placeholder-svg {
    width: 60%;
    height: 60%;
  }

  /* ── Content ── */
  #{{ section_id }} .promo-card__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: {{ section.settings.content_padding }}px {{ section.settings.content_padding }}px {{ section.settings.content_padding | plus: 4 }}px;
    gap: {{ section.settings.content_gap }}px;
  }

  #{{ section_id }} .promo-card__label {
    margin: 0;
    padding: 0;
    letter-spacing: 0.02em;
  }

  #{{ section_id }} .promo-card__heading {
    margin: 0;
    padding: 0;
  }

  /* ── Button ── */
  #{{ section_id }} .promo-card__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ section.settings.btn_padding_v }}px {{ section.settings.btn_padding_h }}px;
    text-decoration: none;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
    white-space: nowrap;
    margin-top: {{ section.settings.btn_margin_top }}px;
  }
  #{{ section_id }} .promo-card__btn:hover {
    background-color: var(--btn-hover-bg) !important;
    color: var(--btn-hover-text) !important;
    border-color: var(--btn-hover-border) !important;
  }

  /* ── Mobile ── */
  @media screen and (max-width: 749px) {
    #{{ section_id }} .promo-cards__grid {
      grid-template-columns: 1fr;
      gap: {{ section.settings.card_gap_mobile }}px;
    }
    #{{ section_id }} .promo-card__img {
      {% if section.settings.adapt_to_image %}
        max-height: {{ section.settings.image_height_mobile }}px;
      {% else %}
        height: {{ section.settings.image_height_mobile }}px;
      {% endif %}
    }
    #{{ section_id }} .promo-card__img-placeholder {
      height: {{ section.settings.image_height_mobile }}px;
    }
  }
</style>

{% schema %}
{
  "name": "Promo Cards",
  "tag": "section",
  "class": "promo-cards-section",
  "max_blocks": 3,
  "settings": [
    {
      "type": "header",
      "content": "Section"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Section background",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Padding top",
      "min": 0, "max": 100, "step": 4, "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Padding bottom",
      "min": 0, "max": 100, "step": 4, "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "section_padding_x",
      "label": "Padding left & right",
      "min": 0, "max": 80, "step": 4, "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Cards"
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card border radius",
      "min": 0, "max": 32, "step": 2, "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "card_gap",
      "label": "Gap between cards (desktop)",
      "min": 0, "max": 40, "step": 2, "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "card_gap_mobile",
      "label": "Gap between cards (mobile)",
      "min": 0, "max": 40, "step": 2, "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "checkbox",
      "id": "adapt_to_image",
      "label": "Adapt to image height",
      "info": "When on, the image shows at its natural height up to the max. When off, a fixed height crops the image.",
      "default": true
    },
    {
      "type": "range",
      "id": "image_height",
      "label": "Max image height (desktop)",
      "min": 200, "max": 700, "step": 10, "unit": "px",
      "default": 480
    },
    {
      "type": "range",
      "id": "image_height_mobile",
      "label": "Max image height (mobile)",
      "min": 200, "max": 600, "step": 10, "unit": "px",
      "default": 320
    },
    {
      "type": "range",
      "id": "image_padding_x",
      "label": "Image padding left & right",
      "min": 0, "max": 40, "step": 2, "unit": "px",
      "default": 10
    },
    {
      "type": "header",
      "content": "Label text"
    },
    {
      "type": "range",
      "id": "label_size",
      "label": "Font size",
      "min": 10, "max": 24, "step": 1, "unit": "px",
      "default": 13
    },
    {
      "type": "select",
      "id": "label_weight",
      "label": "Font weight",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-bold" }
      ],
      "default": "400"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Font size",
      "min": 16, "max": 72, "step": 2, "unit": "px",
      "default": 40
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Font weight",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" },
        { "value": "800", "label": "Extra bold" }
      ],
      "default": "700"
    },
    {
      "type": "select",
      "id": "heading_line_height",
      "label": "Line height",
      "options": [
        { "value": "1",   "label": "Tight — 1" },
        { "value": "1.1", "label": "1.1" },
        { "value": "1.2", "label": "1.2" },
        { "value": "1.3", "label": "Normal — 1.3" }
      ],
      "default": "1.1"
    },
    {
      "type": "header",
      "content": "Content area"
    },
    {
      "type": "range",
      "id": "content_padding",
      "label": "Content padding",
      "min": 8, "max": 48, "step": 4, "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "content_gap",
      "label": "Gap between label, heading, button",
      "min": 0, "max": 24, "step": 2, "unit": "px",
      "default": 6
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "range",
      "id": "btn_font_size",
      "label": "Font size",
      "min": 11, "max": 22, "step": 1, "unit": "px",
      "default": 14
    },
    {
      "type": "select",
      "id": "btn_font_weight",
      "label": "Font weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "600"
    },
    {
      "type": "range",
      "id": "btn_radius",
      "label": "Border radius",
      "min": 0, "max": 40, "step": 2, "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "btn_border_width",
      "label": "Border width",
      "min": 0, "max": 4, "step": 1, "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "btn_padding_v",
      "label": "Padding top & bottom",
      "min": 6, "max": 24, "step": 2, "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "btn_padding_h",
      "label": "Padding left & right",
      "min": 12, "max": 60, "step": 4, "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "btn_margin_top",
      "label": "Space above button",
      "min": 0, "max": 32, "step": 2, "unit": "px",
      "default": 8
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Promo card",
      "settings": [
        {
          "type": "header",
          "content": "Card"
        },
        {
          "type": "color",
          "id": "card_bg",
          "label": "Card background color",
          "default": "#eee8d8"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "header",
          "content": "Label"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label text",
          "default": "Fresh everyday"
        },
        {
          "type": "color",
          "id": "label_color",
          "label": "Label color",
          "default": "#3d3d3a"
        },
        {
          "type": "header",
          "content": "Heading"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading text",
          "default": "Finest Bread"
        },
        {
          "type": "color",
          "id": "heading_color",
          "label": "Heading color",
          "default": "#1a1a1a"
        },
        {
          "type": "header",
          "content": "Button"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Show more"
        },
        {
          "type": "url",
          "id": "button_url",
          "label": "Button link"
        },
        {
          "type": "header",
          "content": "Button — default state"
        },
        {
          "type": "color",
          "id": "btn_bg",
          "label": "Background",
          "default": "#1a1a1a"
        },
        {
          "type": "color",
          "id": "btn_text",
          "label": "Text color",
          "default": "#ffffff"
        },
        {
          "type": "color",
          "id": "btn_border_color",
          "label": "Border color",
          "default": "#1a1a1a"
        },
        {
          "type": "header",
          "content": "Button — hover state"
        },
        {
          "type": "color",
          "id": "btn_hover_bg",
          "label": "Background",
          "default": "#ffffff"
        },
        {
          "type": "color",
          "id": "btn_hover_text",
          "label": "Text color",
          "default": "#1a1a1a"
        },
        {
          "type": "color",
          "id": "btn_hover_border",
          "label": "Border color",
          "default": "#1a1a1a"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Promo Cards",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "card_bg": "#e8e2d0",
            "label": "Fresh everyday",
            "heading": "Finest Bread",
            "button_label": "Show more"
          }
        },
        {
          "type": "card",
          "settings": {
            "card_bg": "#d8e8d8",
            "label": "Just arrived!",
            "heading": "Superfoods",
            "button_label": "Show more"
          }
        },
        {
          "type": "card",
          "settings": {
            "card_bg": "#d0dce8",
            "label": "Collection",
            "heading": "Pure Organic",
            "button_label": "Show more"
          }
        }
      ]
    }
  ]
}
{% endschema %}
