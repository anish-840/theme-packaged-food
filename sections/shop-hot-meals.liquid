{% comment %}
  Shop Hot Meals — Split Layout Section
  Desktop: bg image left (~55%), product cards carousel right (~45%), 2 visible
  Mobile:  bg image full-width top, product cards 2-col carousel below, 1/N pagination
{% endcomment %}

{%- liquid
  assign sid           = 'shm-' | append: section.id
  assign collection    = collections[section.settings.collection]
  assign products_list = collection.products
  assign desk_cols     = 2
  assign mob_cols      = 2
  assign total         = products_list.size
  assign card_gap      = section.settings.card_gap
-%}

<section id="{{ sid }}" class="shm-section">

  {%- comment %} ── Background image (desktop left, mobile top) ── {%- endcomment %}
  <div class="shm-bg">
    {%- if section.settings.bg_image != blank -%}
      {{
        section.settings.bg_image
        | image_url: width: 1400
        | image_tag:
          class: 'shm-bg__img shm-bg__img--desktop',
          loading: 'lazy',
          widths: '600, 900, 1200, 1400',
          sizes: '55vw',
          alt: section.settings.bg_image.alt | default: section.settings.title | escape
      }}
    {%- endif -%}
    {%- if section.settings.bg_image_mobile != blank -%}
      {{
        section.settings.bg_image_mobile
        | image_url: width: 800
        | image_tag:
          class: 'shm-bg__img shm-bg__img--mobile',
          loading: 'lazy',
          widths: '400, 600, 800',
          sizes: '100vw',
          alt: section.settings.bg_image_mobile.alt | default: section.settings.title | escape
      }}
    {%- elsif section.settings.bg_image != blank -%}
      {{
        section.settings.bg_image
        | image_url: width: 800
        | image_tag:
          class: 'shm-bg__img shm-bg__img--mobile',
          loading: 'lazy',
          widths: '400, 600, 800',
          sizes: '100vw',
          alt: section.settings.bg_image.alt | default: section.settings.title | escape
      }}
    {%- endif -%}
  </div>

  {%- comment %} ── Right panel ── {%- endcomment %}
  <div class="shm-panel">

    {%- comment %} Section title {%- endcomment %}
    {%- if section.settings.title != blank -%}
      <h2 class="shm-title">{{ section.settings.title | escape }}</h2>
    {%- endif -%}

    {%- comment %} Cards viewport {%- endcomment %}
    <div class="shm-viewport">
      <div class="shm-track" data-shm-track>
        {%- for product in products_list -%}
          <div class="shm-item">
            <a href="{{ product.url }}" class="shm-card">

              <div class="shm-card__media">
                {%- if product.featured_media != blank -%}
                  {{
                    product.featured_media.preview_image
                    | image_url: width: 600
                    | image_tag:
                      class: 'shm-card__img',
                      loading: 'lazy',
                      widths: '200, 300, 400, 600',
                      sizes: '(max-width: 749px) 45vw, 20vw',
                      alt: product.featured_media.alt | default: product.title | escape
                  }}
                {%- else -%}
                  <div class="shm-card__placeholder">
                    {{ 'product-1' | placeholder_svg_tag: 'shm-placeholder-svg' }}
                  </div>
                {%- endif -%}
              </div>

              <div class="shm-card__body">
                <p class="shm-card__price">
                  {%- if product.price_varies -%}
                    {{ 'products.product.from_text_html' | t: price: product.price_min | money }}
                    {%- assign price_prefix = 'From ' -%}
                    From {{ product.price_min | money }}
                  {%- else -%}
                    {{ product.price | money }}
                  {%- endif -%}
                </p>
                <h3 class="shm-card__title">{{ product.title }}</h3>

                {%- comment %} Star rating from metafield if available {%- endcomment %}
                {%- assign rating = product.metafields.reviews.rating.value -%}
                {%- if rating != blank -%}
                  <div class="shm-card__stars" aria-label="Rating: {{ rating }} out of 5">
                    {%- assign full  = rating | floor -%}
                    {%- assign half  = rating | minus: full -%}
                    {%- for i in (1..5) -%}
                      {%- if i <= full -%}
                        <svg width="14" height="14" viewBox="0 0 14 14" fill="#1a1a1a" aria-hidden="true"><path d="M7 1l1.545 3.13L12 4.635l-2.5 2.435.59 3.44L7 8.885l-3.09 1.625.59-3.44L2 4.635l3.455-.505z"/></svg>
                      {%- elsif half >= 0.5 -%}
                        <svg width="14" height="14" viewBox="0 0 14 14" aria-hidden="true"><defs><linearGradient id="h{{ forloop.index }}{{ sid }}"><stop offset="50%" stop-color="#1a1a1a"/><stop offset="50%" stop-color="#d0d0d0"/></linearGradient></defs><path d="M7 1l1.545 3.13L12 4.635l-2.5 2.435.59 3.44L7 8.885l-3.09 1.625.59-3.44L2 4.635l3.455-.505z" fill="url(#h{{ forloop.index }}{{ sid }})"/></svg>
                        {%- assign half = 0 -%}
                      {%- else -%}
                        <svg width="14" height="14" viewBox="0 0 14 14" fill="#d0d0d0" aria-hidden="true"><path d="M7 1l1.545 3.13L12 4.635l-2.5 2.435.59 3.44L7 8.885l-3.09 1.625.59-3.44L2 4.635l3.455-.505z"/></svg>
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                {%- endif -%}

                <span class="shm-card__btn">{{ section.settings.btn_label | default: 'Buy now' }}</span>
              </div>

            </a>
          </div>
        {%- else -%}
          {%- comment %} Placeholder cards if no collection set {%- endcomment %}
          {%- for i in (1..4) -%}
            <div class="shm-item">
              <div class="shm-card">
                <div class="shm-card__media">
                  {{ 'product-' | append: i | placeholder_svg_tag: 'shm-placeholder-svg' }}
                </div>
                <div class="shm-card__body">
                  <p class="shm-card__price">From $6.00</p>
                  <h3 class="shm-card__title">Product title</h3>
                  <span class="shm-card__btn">{{ section.settings.btn_label | default: 'Buy now' }}</span>
                </div>
              </div>
            </div>
          {%- endfor -%}
        {%- endfor -%}
      </div>
    </div>

    {%- comment %} ── Nav bar — dots + arrows desktop / counter mobile ── {%- endcomment %}
    <div
      class="shm-nav"
      style="
        --ind-active: {{ section.settings.ind_active_color }};
        --ind-inactive: {{ section.settings.ind_inactive_color }};
      "
    >
      <button class="shm-arrow shm-arrow--prev" type="button" aria-label="Previous">
        <svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M12.5 15L7.5 10L12.5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <div class="shm-dots" data-shm-dots></div>
      <span class="shm-counter" data-shm-counter>1 / 1</span>
      <button class="shm-arrow shm-arrow--next" type="button" aria-label="Next">
        <svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M7.5 5L12.5 10L7.5 15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>

  </div>
  {%- comment %} ── /Right panel ── {%- endcomment %}

</section>

<style>
  #{{ sid }} {
    position: relative;
    display: grid;
    grid-template-columns: {{ section.settings.bg_width }}fr {{ section.settings.panel_width }}fr;
    min-height: {{ section.settings.section_height }}px;
    background: {{ section.settings.section_bg }};
    overflow: hidden;
  }

  /* ── Background image ── */
  #{{ sid }} .shm-bg {
    position: relative;
    overflow: hidden;
    border-radius: {{ section.settings.bg_radius }}px;
    margin: {{ section.settings.bg_margin }}px;
  }
  #{{ sid }} .shm-bg__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }
  #{{ sid }} .shm-bg__img--mobile { display: none; }
  #{{ sid }} .shm-bg__img--desktop { display: block; }

  /* ── Right panel ── */
  #{{ sid }} .shm-panel {
    display: flex;
    flex-direction: column;
    padding: {{ section.settings.panel_padding }}px {{ section.settings.panel_padding }}px {{ section.settings.panel_padding | divided_by: 2 }}px;
    gap: {{ section.settings.panel_gap }}px;
    justify-content: center;
  }

  /* ── Title ── */
  #{{ sid }} .shm-title {
    font-size: {{ section.settings.title_size }}px;
    font-weight: {{ section.settings.title_weight }};
    color: {{ section.settings.title_color }};
    margin: 0; padding: 0;
    line-height: 1.2;
  }

  /* ── Viewport ── */
  #{{ sid }} .shm-viewport {
    overflow: hidden;
    width: 100%;
  }
  #{{ sid }} .shm-track {
    display: flex;
    gap: {{ card_gap }}px;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform;
  }
  #{{ sid }} .shm-item {
    flex: 0 0 calc((100% - {{ card_gap }}px) / 2);
    min-width: 0;
  }

  /* ── Card ── */
  #{{ sid }} .shm-card {
    display: flex;
    flex-direction: column;
    background: {{ section.settings.card_bg }};
    border: {{ section.settings.card_border_width }}px solid {{ section.settings.card_border_color }};
    border-radius: {{ section.settings.card_radius }}px;
    overflow: hidden;
    text-decoration: none;
    transition: box-shadow 0.2s ease;
    height: 100%;
  }
  #{{ sid }} .shm-card:hover {
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
  }

  /* ── Card media ── */
  #{{ sid }} .shm-card__media {
    width: 100%;
    aspect-ratio: {{ section.settings.card_img_ratio }};
    overflow: hidden;
    background: {{ section.settings.card_img_bg }};
    display: flex;
    align-items: center;
    justify-content: center;
  }
  #{{ sid }} .shm-card__img {
    width: 100%;
    height: 100%;
    object-fit: {{ section.settings.card_img_fit }};
    object-position: center;
    display: block;
    transition: transform 0.3s ease;
  }
  #{{ sid }} .shm-card:hover .shm-card__img {
    transform: scale(1.04);
  }
  #{{ sid }} .shm-placeholder-svg {
    width: 60%; height: 60%; opacity: 0.2;
  }

  /* ── Card body ── */
  #{{ sid }} .shm-card__body {
    padding: {{ section.settings.card_padding }}px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    flex: 1;
  }
  #{{ sid }} .shm-card__price {
    font-size: {{ section.settings.price_size }}px;
    font-weight: {{ section.settings.price_weight }};
    color: {{ section.settings.price_color }};
    margin: 0; padding: 0;
  }
  #{{ sid }} .shm-card__title {
    font-size: {{ section.settings.card_title_size }}px;
    font-weight: {{ section.settings.card_title_weight }};
    color: {{ section.settings.card_title_color }};
    margin: 0; padding: 0;
    line-height: 1.3;
  }
  #{{ sid }} .shm-card__stars {
    display: flex;
    gap: 2px;
    align-items: center;
  }

  /* ── Card button ── */
  #{{ sid }} .shm-card__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: auto;
    padding: {{ section.settings.btn_padding_v }}px {{ section.settings.btn_padding_h }}px;
    border-radius: {{ section.settings.btn_radius }}px;
    border: {{ section.settings.btn_border_width }}px solid {{ section.settings.btn_border_color }};
    background: {{ section.settings.btn_bg }};
    color: {{ section.settings.btn_text_color }};
    font-size: {{ section.settings.btn_font_size }}px;
    font-weight: {{ section.settings.btn_font_weight }};
    transition: background 0.2s, color 0.2s, border-color 0.2s;
    text-align: center;
  }
  #{{ sid }} .shm-card:hover .shm-card__btn {
    background: {{ section.settings.btn_hover_bg }};
    color: {{ section.settings.btn_hover_text }};
    border-color: {{ section.settings.btn_hover_border }};
  }

  /* ── Nav ── */
  #{{ sid }} .shm-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    height: {{ section.settings.nav_height }}px;
  }
  #{{ sid }} .shm-arrow {
    width: 32px; height: 32px;
    border-radius: 50%;
    border: none;
    background: transparent;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    color: {{ section.settings.arrow_color }};
    transition: background 0.15s;
    padding: 0; flex-shrink: 0;
  }
  #{{ sid }} .shm-arrow:hover { background: rgba(0,0,0,0.06); }
  #{{ sid }} .shm-arrow:disabled { opacity: 0.3; cursor: default; }

  /* Dots — desktop */
  #{{ sid }} .shm-dots {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  #{{ sid }} .shm-dot {
    width: 28px; height: 6px;
    border-radius: 3px;
    border: none; padding: 0; cursor: pointer;
    background: var(--ind-inactive);
    transition: background 0.2s, width 0.3s;
  }
  #{{ sid }} .shm-dot.is-active {
    background: var(--ind-active);
    width: 40px;
  }

  /* Counter — mobile only */
  #{{ sid }} .shm-counter {
    display: none;
    font-size: 14px;
    font-weight: 500;
    color: {{ section.settings.arrow_color }};
    min-width: 40px;
    text-align: center;
  }

  /* ══════════════════════════════════
     MOBILE
  ══════════════════════════════════ */
  @media screen and (max-width: 749px) {
    #{{ sid }} {
      grid-template-columns: 1fr;
      grid-template-rows: auto 1fr;
      min-height: unset;
    }

    /* Bg image: full width, fixed height on mobile */
    #{{ sid }} .shm-bg {
      border-radius: {{ section.settings.bg_radius_mobile }}px;
      margin: {{ section.settings.bg_margin_mobile }}px;
      height: {{ section.settings.bg_height_mobile }}px;
    }
    #{{ sid }} .shm-bg__img--desktop { display: none !important; }
    #{{ sid }} .shm-bg__img--mobile  { display: block !important; }

    #{{ sid }} .shm-panel {
      padding: {{ section.settings.panel_padding | divided_by: 2 }}px {{ section.settings.panel_padding | divided_by: 2 }}px {{ section.settings.panel_padding | divided_by: 4 }}px;
    }

    /* 2 cols on mobile — same as desktop */
    #{{ sid }} .shm-item {
      flex: 0 0 calc((100% - {{ card_gap }}px) / 2);
    }

    /* Counter visible, dots hidden on mobile */
    #{{ sid }} .shm-dots   { display: none; }
    #{{ sid }} .shm-counter { display: block; }

    #{{ sid }} .shm-title {
      font-size: {{ section.settings.title_size | times: 0.8 | round }}px;
    }
  }
</style>

<script>
(function() {
  var section  = document.getElementById('{{ sid }}');
  if (!section) return;

  var track    = section.querySelector('[data-shm-track]');
  var dotsWrap = section.querySelector('[data-shm-dots]');
  var counter  = section.querySelector('[data-shm-counter]');
  var prevBtn  = section.querySelector('.shm-arrow--prev');
  var nextBtn  = section.querySelector('.shm-arrow--next');
  var items    = Array.from(track ? track.querySelectorAll('.shm-item') : []);
  if (!track || items.length === 0) return;

  var current  = 0;
  var gap      = parseInt('{{ card_gap }}', 10) || 16;

  function cols() {
    return 2;
  }

  function pages() {
    return Math.ceil(items.length / cols());
  }

  function itemWidth() {
    var vw = track.parentElement.offsetWidth;
    return (vw + gap) / cols();
  }

  function buildDots() {
    if (!dotsWrap) return;
    dotsWrap.innerHTML = '';
    for (var i = 0; i < pages(); i++) {
      var btn = document.createElement('button');
      btn.className = 'shm-dot' + (i === 0 ? ' is-active' : '');
      btn.type = 'button';
      btn.setAttribute('aria-label', 'Go to page ' + (i + 1));
      btn.dataset.page = i;
      dotsWrap.appendChild(btn);
    }
  }

  function goTo(page) {
    var p = Math.max(0, Math.min(page, pages() - 1));
    current = p;

    var offset = p * cols() * itemWidth();
    var maxOff = track.scrollWidth - track.parentElement.offsetWidth;
    offset = Math.min(offset, maxOff);
    track.style.transform = 'translateX(-' + offset + 'px)';

    /* dots */
    Array.from(dotsWrap.querySelectorAll('.shm-dot')).forEach(function(d, i) {
      d.classList.toggle('is-active', i === current);
    });

    /* counter */
    if (counter) counter.textContent = (current + 1) + ' / ' + pages();

    /* arrows */
    if (prevBtn) prevBtn.disabled = current === 0;
    if (nextBtn) nextBtn.disabled = current >= pages() - 1;
  }

  function init() {
    buildDots();
    goTo(0);
  }

  if (prevBtn) prevBtn.addEventListener('click', function() { goTo(current - 1); });
  if (nextBtn) nextBtn.addEventListener('click', function() { goTo(current + 1); });

  if (dotsWrap) {
    dotsWrap.addEventListener('click', function(e) {
      var btn = e.target.closest('.shm-dot');
      if (btn) goTo(parseInt(btn.dataset.page, 10));
    });
  }

  /* Swipe */
  var tx = 0;
  track.addEventListener('touchstart', function(e) { tx = e.touches[0].clientX; }, { passive: true });
  track.addEventListener('touchend', function(e) {
    var diff = tx - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 40) diff > 0 ? goTo(current + 1) : goTo(current - 1);
  }, { passive: true });

  var rt;
  window.addEventListener('resize', function() {
    clearTimeout(rt);
    rt = setTimeout(init, 150);
  });

  init();
})();
</script>

{% schema %}
{
  "name": "Shop Hot Meals",
  "tag": "section",
  "class": "shop-hot-meals-section",
  "settings": [
    {
      "type": "header",
      "content": "Section"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section title",
      "default": "Shop Hot Meals"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Section background",
      "default": "#f0f0ee"
    },
    {
      "type": "range",
      "id": "section_height",
      "label": "Min height (desktop)",
      "min": 300, "max": 900, "step": 20, "unit": "px",
      "default": 560
    },
    {
      "type": "header",
      "content": "Title"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Font size",
      "min": 14, "max": 48, "step": 1, "unit": "px",
      "default": 22
    },
    {
      "type": "select",
      "id": "title_weight",
      "label": "Font weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "500"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Color",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "Background image"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Desktop background image"
    },
    {
      "type": "image_picker",
      "id": "bg_image_mobile",
      "label": "Mobile background image",
      "info": "Falls back to desktop image if not set"
    },
    {
      "type": "range",
      "id": "bg_width",
      "label": "Background image column width (fr)",
      "min": 1, "max": 4, "step": 1,
      "default": 1,
      "info": "Ratio vs panel column. E.g. 1:1 = 50/50, 3:2 = 60/40"
    },
    {
      "type": "range",
      "id": "panel_width",
      "label": "Products panel column width (fr)",
      "min": 1, "max": 4, "step": 1,
      "default": 1
    },
    {
      "type": "range",
      "id": "bg_radius",
      "label": "Background image border radius",
      "min": 0, "max": 24, "step": 2, "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "bg_margin",
      "label": "Background image margin",
      "min": 0, "max": 32, "step": 4, "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "bg_height_mobile",
      "label": "Background image height (mobile)",
      "min": 160, "max": 600, "step": 10, "unit": "px",
      "default": 300
    },
    {
      "type": "range",
      "id": "bg_radius_mobile",
      "label": "Background image border radius (mobile)",
      "min": 0, "max": 24, "step": 2, "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "bg_margin_mobile",
      "label": "Background image margin (mobile)",
      "min": 0, "max": 24, "step": 4, "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Products panel"
    },
    {
      "type": "range",
      "id": "panel_padding",
      "label": "Panel padding",
      "min": 8, "max": 60, "step": 4, "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "panel_gap",
      "label": "Gap between title and cards",
      "min": 0, "max": 40, "step": 4, "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Cards"
    },
    {
      "type": "range",
      "id": "card_gap",
      "label": "Gap between cards",
      "min": 4, "max": 32, "step": 2, "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card border radius",
      "min": 0, "max": 24, "step": 2, "unit": "px",
      "default": 12
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Card border color",
      "default": "#e8e8e8"
    },
    {
      "type": "range",
      "id": "card_border_width",
      "label": "Card border width",
      "min": 0, "max": 4, "step": 1, "unit": "px",
      "default": 1
    },
    {
      "type": "select",
      "id": "card_img_ratio",
      "label": "Card image ratio",
      "options": [
        { "value": "1 / 1",  "label": "Square 1:1" },
        { "value": "4 / 3",  "label": "Landscape 4:3" },
        { "value": "3 / 4",  "label": "Portrait 3:4" }
      ],
      "default": "1 / 1"
    },
    {
      "type": "select",
      "id": "card_img_fit",
      "label": "Card image fit",
      "options": [
